# Docker Environment Variables Template
# Copy this file to .env and fill in your actual values
# Do NOT commit .env file to git

# Docker Environment Variables
SQL_PASSWORD=HobbyShop@2026
CLOUDFLARE_TOKEN=YOUR_CLOUDFLARE_TOKEN_HERE
# Mail Settings
MailSettings__Email=YOUR_EMAIL_HERE
MailSettings__Password=YOUR_PASSWORD_HERE

# Connection String
ConnectionStrings__MyConnectString=Server=hobbyshop-db;Database=Ecommerce_Hobby_Shop;User Id=sa;Password=HobbyShop@2026;TrustServerCertificate=True

# ASP.NET Core Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Gemini AI Settings
Gemini__ApiKey=YOUR_GEMINI_API_KEY_HERE
Gemini__Model=gemini-3.1-flash-lite