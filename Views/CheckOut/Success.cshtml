@{
    ViewData["Title"] = Loc.T("Đặt hàng thành công", "Order Successful");
}



<div class="success-wrapper">
    <canvas id="confetti-canvas"></canvas>
    <div class="success-card">
        <div class="success-icon-container">
            <i class="fa fa-check"></i>
        </div>
        <h2 class="fw-bold text-success mb-3">@Loc.T("Đặt Hàng Thành Công!", "Order Placed Successfully!")</h2>
        <p class="text-muted mb-4">@Loc.T("Cảm ơn bạn đã mua sắm tại Hobby Shop. Đơn hàng của bạn sẽ được đóng gói và giao sớm nhất.", "Thank you for shopping at Hobby Shop. Your order will be packed and shipped as soon as possible.")</p>
        
        <div class="p-3 bg-light rounded mb-4 text-start">
            <p class="mb-1"><strong>@Loc.T("Mã đơn hàng:", "Order ID:")</strong> <span class="text-primary fw-bold">#@ViewBag.OrderId</span></p>
            <p class="mb-0"><strong>@Loc.T("Phương thức:", "Method:")</strong> @Loc.T("Thanh toán khi nhận hàng (COD)", "Cash on Delivery (COD)")</p>
        </div>

        <div class="d-grid gap-2">
            <a asp-controller="Orders" asp-action="History" class="btn text-white fw-bold py-2 rounded shadow-sm" style="background: #7F56D9;">
                @Loc.T("XEM LỊCH SỬ ĐƠN HÀNG", "VIEW ORDER HISTORY")
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary fw-bold py-2 rounded">
                @Loc.T("TIẾP TỤC MUA SẮM", "CONTINUE SHOPPING")
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple JS Confetti Particle System
        document.addEventListener('DOMContentLoaded', function () {
            var canvas = document.getElementById('confetti-canvas');
            var ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            var confetti = [];
            var confettiCount = 150;
            var colors = ['#f44336', '#e91e63', '#9c27b0', '#673ab7', '#3f51b5', '#2196f3', '#03a9f4', '#00bcd4', '#009688', '#4CAF50', '#8BC34A', '#CDDC39', '#FFEB3B', '#FFC107', '#FF9800', '#FF5722'];

            function ConfettiParticle() {
                this.x = canvas.width / 2;
                this.y = canvas.height / 2 + 100;
                this.r = Math.random() * 6 + 2;
                this.dx = Math.random() * 10 - 5;
                this.dy = Math.random() * -10 - 5;
                this.color = colors[Math.floor(Math.random() * colors.length)];
                this.tilt = Math.floor(Math.random() * 10) - 10;
                this.tiltAngleInc = (Math.random() * 0.07) + 0.05;
                this.tiltAngle = 0;

                this.draw = function () {
                    ctx.beginPath();
                    ctx.lineWidth = this.r;
                    ctx.strokeStyle = this.color;
                    ctx.moveTo(this.x + this.tilt + this.r, this.y);
                    ctx.lineTo(this.x + this.tilt, this.y + this.tilt + this.r);
                    ctx.stroke();
                }

                this.update = function () {
                    this.dy += 0.2; // gravity
                    this.x += this.dx;
                    this.y += this.dy;
                    this.tiltAngle += this.tiltAngleInc;
                    this.tilt = Math.sin(this.tiltAngle) * 15;
                    this.draw();
                }
            }

            for (var i = 0; i < confettiCount; i++) {
                confetti.push(new ConfettiParticle());
            }

            function animate() {
                requestAnimationFrame(animate);
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (var i = 0; i < confettiCount; i++) {
                    confetti[i].update();
                }
            }

            animate();

            // Resize handle
            window.addEventListener('resize', function () {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            });
            
            // Dọn toast báo hiệu rỗng từ logic chung nếu có
            $('.toast').remove();
        });
    </script>
}