@{
    ViewData["Title"] = Loc.T("Thanh toán thành công", "Payment Successful");
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fa fa-check-circle text-success" style="font-size: 80px;"></i>
                    </div>
                    <h2 class="fw-bold text-success mb-3">@Loc.T("Thanh toán thành công!", "Payment Successful!")</h2>
                    <p class="text-muted mb-4">@Loc.T("Cảm ơn bạn đã mua sắm tại Hobby Shop. Đơn hàng của bạn đã được thanh toán và đang được xử lý.", "Thank you for shopping at Hobby Shop. Your order has been paid and is being processed.")</p>
                    
                    @if (ViewBag.OrderId != null)
                    {
                        <div class="bg-light rounded p-3 mb-4 text-start">
                            <p class="mb-1"><strong>@Loc.T("Mã đơn hàng:", "Order ID:")</strong> #@ViewBag.OrderId</p>
                        </div>
                    }

                    <a href="@Url.Action("History", "Orders")" class="btn payment-primary-btn w-100 py-2 fw-bold rounded-3 mb-2">
                        @Loc.T("XEM LỊCH SỬ ĐƠN HÀNG", "VIEW ORDER HISTORY")
                    </a>
                    <a href="@Url.Action("Index", "Home")" class="btn payment-secondary-btn w-100 py-2 fw-bold rounded-3">
                        @Loc.T("TIẾP TỤC MUA SẮM", "CONTINUE SHOPPING")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
