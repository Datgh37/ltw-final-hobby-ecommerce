@{
    ViewData["Title"] = Loc.T("Thanh toán thất bại", "Payment Failed");
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fa fa-times-circle text-danger" style="font-size: 80px;"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">@Loc.T("Thanh toán thất bại!", "Payment Failed!")</h2>
                    <p class="text-muted mb-4">@Loc.T("Rất tiếc, giao dịch thanh toán của bạn không thành công hoặc đã bị hủy.", "Sorry, your payment transaction failed or was canceled.")</p>
                    
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-warning mb-4 text-start">
                            <strong>@Loc.T("Lý do:", "Reason:")</strong> @ViewBag.Message
                        </div>
                    }

                    <div class="alert alert-info small text-start mb-4">
                        <i class="fa fa-info-circle me-1"></i> @Loc.T("Đơn hàng của bạn đã được ghi nhận với trạng thái 'Chưa thanh toán'. Bạn có thể thanh toán lại trong phần Lịch sử đơn hàng hoặc liên hệ CSKH.", "Your order has been recorded as 'Unpaid'. You can pay again in the Order History section or contact Customer Support.")
                    </div>

                    <a href="@Url.Action("History", "Orders")" class="btn payment-primary-btn w-100 py-2 fw-bold rounded-3 mb-2">
                        @Loc.T("ĐI ĐẾN ĐƠN HÀNG CỦA TÔI", "GO TO MY ORDERS")
                    </a>
                    <a href="@Url.Action("Index", "Cart")" class="btn payment-secondary-btn w-100 py-2 fw-bold rounded-3">
                        @Loc.T("QUAY LẠI GIỎ HÀNG", "BACK TO CART")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
