@using TuNhanTamTInh_Ecommerce.Models.ViewModels
@model TuNhanTamTInh_Ecommerce.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";

    var breadcrumb = new BreadcrumbViewModel
    {
        Title = "Đổi mật khẩu",
        Items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", Url.Action("Index", "Home")),
            new BreadcrumbItem("Hồ sơ", Url.Action("Profile", "Account")),
            new BreadcrumbItem("Đổi mật khẩu")
        }
    };
}

<div id="toast-container"></div>
<partial name="_Breadcrumb" model="breadcrumb" />

<section class="spad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card auth-card-premium rounded-lg">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="fa fa-lock fa-4x text-purple"></i>
                            </div>
                            <h3 class="font-weight-bold text-dark">Bảo Mật Tài Khoản</h3>
                            <p class="text-muted">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để cập nhật.</p>
                        </div>

                        <form id="changePasswordForm" asp-action="ChangePassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="form-group mb-4">
                                <label asp-for="OldPassword" class="text-muted font-weight-bold mb-2">Mật khẩu hiện tại</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text input-group-text-small"><i class="fa fa-key"></i></span>
                                    </div>
                                    <div class="password-wrapper flex-grow-1">
                                        <input asp-for="OldPassword" type="password" class="form-control auth-input-small" placeholder="Nhập mật khẩu hiện tại" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                </div>
                                <span asp-validation-for="OldPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="NewPassword" class="text-muted font-weight-bold mb-2">Mật khẩu mới</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text input-group-text-small"><i class="fa fa-lock"></i></span>
                                    </div>
                                    <div class="password-wrapper flex-grow-1">
                                        <input asp-for="NewPassword" type="password" class="form-control auth-input-small" placeholder="Nhập mật khẩu mới" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="text-muted font-weight-bold mb-2">Xác nhận mật khẩu mới</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text input-group-text-small"><i class="fa fa-check"></i></span>
                                    </div>
                                    <div class="password-wrapper flex-grow-1">
                                        <input asp-for="ConfirmPassword" type="password" class="form-control auth-input-small" placeholder="Xác nhận mật khẩu mới" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="mt-5 text-center d-flex flex-column align-items-center">
                                <button type="submit" id="btnChangePassword" class="site-btn rounded-pill px-5 text-uppercase mb-3">
                                    <i class="fa fa-key mr-2"></i> Cập Nhật Mật Khẩu
                                </button>
                                <a asp-action="Profile" class="text-muted no-decoration"><i class="fa fa-arrow-left mr-2"></i> Hủy và quay lại</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `toast-msg toast-${type}`;
            toast.innerHTML = `<i class="fa ${type === 'success' ? 'fa-check-circle' : (type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle')} mr-2"></i> ${message}`;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        $(document).ready(function() {
            $('#changePasswordForm').submit(function(e) {
                e.preventDefault();
                
                var $btn = $('#btnChangePassword');
                $btn.prop('disabled', true).text('ĐANG XỬ LÝ...');

                $.ajax({
                    url: '/Account/ChangePassword',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => {
                                window.location.href = '@Url.Action("Profile", "Account")';
                            }, 1500);
                        } else {
                            showToast(response.message, 'error');
                            $btn.prop('disabled', false).text('CẬP NHẬT MẬT KHẨU');
                        }
                    },
                    error: function() {
                        showToast("Có lỗi xảy ra khi kết nối server.", 'error');
                        $btn.prop('disabled', false).text('CẬP NHẬT MẬT KHẨU');
                    }
                });
            });
        });
    </script>
}
