@model TuNhanTamTInh_Ecommerce.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner -->
        <div class="col-lg-6 d-none d-lg-block p-0">
            <div class="auth-banner">
                <h2>Chào mừng trở lại!</h2>
                <p>Khám phá thế giới mô hình thu nhỏ vô tận. Đăng nhập để tiếp tục hành trình đam mê của bạn tại TuNhanTamTInh Hobby Shop.</p>
            </div>
        </div>
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <a asp-controller="Home" asp-action="Index" class="back-home"><i class="fa fa-home"></i> Trang chủ</a>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-5">
                        <h3 class="font-weight-bold auth-title">Đăng Nhập</h3>
                        <p class="text-muted">Vui lòng nhập thông tin của bạn</p>
                    </div>
                    
                    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <!-- Thẻ ẩn hiển thị lỗi tổng quan -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger @(ViewData.ModelState.IsValid ? "step-hidden" : "")"></div>
                        
                        <div class="form-group mb-4">
                            <label asp-for="UsernameOrEmail" class="font-weight-bold mb-2">Tên đăng nhập / Email <span class="text-danger">*</span></label>
                            <input asp-for="UsernameOrEmail" class="form-control auth-input" placeholder="Nhập username hoặc email..." />
                            <span asp-validation-for="UsernameOrEmail" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="form-group mb-4">
                            <label asp-for="Password" class="font-weight-bold mb-2">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="password-wrapper">
                                <input asp-for="Password" class="form-control auth-input" placeholder="Nhập mật khẩu..." type="password" />
                                <i class="fa fa-eye password-toggle"></i>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="rememberMe">
                                <label class="form-check-label text-muted auth-helper-text" for="rememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="auth-link auth-helper-text">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn auth-btn w-100">ĐĂNG NHẬP</button>
                        
                        <div class="text-center mt-4">
                            <p class="text-muted auth-footer-text">Chưa có tài khoản? <a asp-controller="Account" asp-action="Register" class="auth-link">Đăng ký ngay</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
