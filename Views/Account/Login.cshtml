@model TuNhanTamTInh_Ecommerce.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = Loc.T("Đăng nhập", "Login");
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner -->
        <div class="col-lg-6 d-none d-lg-block p-0">
            <div class="auth-banner">
                <h2>@Loc.T("Chào mừng trở lại!", "Welcome Back!")</h2>
                <p>@Loc.T("Khám phá thế giới mô hình thu nhỏ vô tận. Đăng nhập để tiếp tục hành trình đam mê của bạn tại TuNhanTamTInh Hobby Shop.", "Discover the endless world of miniature scale models. Sign in to continue your passion at TuNhanTamTInh Hobby Shop.")</p>
            </div>
        </div>
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <div class="auth-header-actions">
                <partial name="_LanguageSelector" view-data='@(new ViewDataDictionary(ViewData) { { "IsAuth", true } })' />
                <span class="auth-divider">|</span>
                <a asp-controller="Home" asp-action="Index" class="back-home-link"><i class="fa fa-home"></i> @Loc.T("Trang chủ", "Home")</a>
            </div>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-5">
                        <h3 class="font-weight-bold auth-title">@Loc.T("Đăng Nhập", "Login")</h3>
                        <p class="text-muted">@Loc.T("Vui lòng nhập thông tin của bạn", "Please enter your credentials")</p>
                    </div>
                    
                    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <!-- Thẻ ẩn hiển thị lỗi tổng quan -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger @(ViewData.ModelState.IsValid ? "step-hidden" : "")"></div>
                        
                        <div class="form-group mb-4">
                            <label asp-for="UsernameOrEmail" class="font-weight-bold mb-2">@Loc.T("Tên đăng nhập / Email", "Username or Email") <span class="text-danger">*</span></label>
                            <input asp-for="UsernameOrEmail" class="form-control auth-input" placeholder="@Loc.T("Nhập username hoặc email...", "Enter username or email...")" />
                            <span asp-validation-for="UsernameOrEmail" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="form-group mb-4">
                            <label asp-for="Password" class="font-weight-bold mb-2">@Loc.T("Mật khẩu", "Password") <span class="text-danger">*</span></label>
                            <div class="password-wrapper">
                                <input asp-for="Password" class="form-control auth-input" placeholder="@Loc.T("Nhập mật khẩu...", "Enter password...")" type="password" />
                                <i class="fa fa-eye password-toggle"></i>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe">
                                <label class="form-check-label text-muted auth-helper-text" for="rememberMe">
                                    @Loc.T("Ghi nhớ tôi", "Remember me")
                                </label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="auth-link auth-helper-text">
                                @Loc.T("Quên mật khẩu?", "Forgot password?")
                            </a>
                        </div>

                        <button type="submit" class="btn auth-btn w-100">@Loc.T("ĐĂNG NHẬP", "LOGIN")</button>
                        
                        <div class="text-center mt-4">
                            <p class="text-muted auth-footer-text">@Loc.T("Chưa có tài khoản?", "Don't have an account?") <a asp-controller="Account" asp-action="Register" class="auth-link">@Loc.T("Đăng ký ngay", "Register now")</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('form').submit(function(e) {
                e.preventDefault();
                const form = $(this);
                const btn = form.find('button[type="submit"]');
                
                btn.prop('disabled', true).text('@Html.Raw(Loc.T("ĐANG XỬ LÝ...", "PROCESSING..."))');
 
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => {
                                window.location.href = response.returnUrl || '/';
                            }, 1000);
                        } else {
                            showToast(response.message, 'error');
                            btn.prop('disabled', false).text('@Html.Raw(Loc.T("ĐĂNG NHẬP", "LOGIN"))');
                        }
                    },
                    error: function() {
                        showToast("@Html.Raw(Loc.T("Có lỗi xảy ra khi đăng nhập.", "An error occurred during login."))", 'error');
                        btn.prop('disabled', false).text('@Html.Raw(Loc.T("ĐĂNG NHẬP", "LOGIN"))');
                    }
                });
            });
        });
    </script>
}
