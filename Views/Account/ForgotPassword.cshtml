@model TuNhanTamTInh_Ecommerce.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner (Same as Login) -->
        <div class="col-lg-6 d-none d-lg-block p-0">
            <div class="auth-banner">
                <h2>Khôi phục mật khẩu</h2>
                <p>Đừng lo lắng! Chỉ cần vài bước đơn giản để lấy lại quyền truy cập vào tài khoản của bạn.</p>
            </div>
        </div>
        
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <a asp-controller="Account" asp-action="Login" class="back-home"><i class="fa fa-arrow-left"></i> Quay lại Đăng nhập</a>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-5">
                        <h3 class="font-weight-bold auth-title">Quên Mật Khẩu</h3>
                        <p class="text-muted">Nhập email để nhận mã xác thực khôi phục</p>
                    </div>
                    
                    <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <!-- Step 1: Nhập Email và nhận mã -->
                        <div id="step1" class="@(ViewData.ModelState.ContainsKey("NewPassword") || ViewData.ModelState.ContainsKey("ConfirmPassword") ? "step-hidden" : "")">
                            <div class="form-group mb-4">
                                <label asp-for="Email" class="font-weight-bold mb-2">Email của bạn <span class="text-danger">*</span></label>
                                <input asp-for="Email" id="emailInput" class="form-control auth-input" placeholder="example@gmail.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label class="font-weight-bold mb-2">Mã xác thực (OTP)</label>
                                <div class="otp-input-group d-flex">
                                    <input asp-for="VerificationCode" id="otpInput" class="form-control auth-input otp-group-input" placeholder="Nhập mã 6 số" />
                                    <button type="button" id="btnSendOTP" class="btn btn-primary otp-group-button">GỬI MÃ</button>
                                </div>
                                <div id="timer" class="small text-muted mt-2 step-hidden">Gửi lại mã sau <span id="countdown">60</span>s</div>
                                <span asp-validation-for="VerificationCode" class="text-danger small"></span>
                            </div>

                            <button type="button" id="btnVerify" class="btn auth-btn w-100 mt-2">TIẾP THEO</button>
                        </div>

                        <!-- Step 2: Nhập mã và Mật khẩu mới -->
                        <div id="step2" class="mt-3 @(ViewData.ModelState.ContainsKey("NewPassword") || ViewData.ModelState.ContainsKey("ConfirmPassword") ? "" : "step-hidden")">
                            <div class="alert alert-info text-center small mb-4 auto-hide" role="alert">
                                <i class="fa fa-envelope-open mr-2"></i> Xác thực thành công. Vui lòng nhập mật khẩu mới.
                            </div>
                            
                            <div class="form-group mb-4">
                                <label asp-for="NewPassword" class="font-weight-bold mb-2">Mật khẩu mới <span class="text-danger">*</span></label>
                                <div class="password-wrapper">
                                    <input asp-for="NewPassword" type="password" class="form-control auth-input" placeholder="Nhập mật khẩu mới" />
                                    <i class="fa fa-eye password-toggle"></i>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="font-weight-bold mb-2">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                                <div class="password-wrapper">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control auth-input" placeholder="Xác nhận mật khẩu mới" />
                                    <i class="fa fa-eye password-toggle"></i>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn auth-btn w-100">ĐỔI MẬT KHẨU</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            let countdown;
            
            // Chặn Enter mặc định của Form
            $('#forgotPasswordForm').on('keyup keypress', function(e) {
                var keyCode = e.keyCode || e.which;
                if (keyCode === 13) { 
                    e.preventDefault();
                    // Nếu đang ở Bước 1, kích hoạt nút Tiếp theo
                    if ($('#step1').is(':visible')) {
                        $('#btnVerify').click();
                    } else {
                        // Nếu đang ở Bước 2, submit form
                        $(this).unbind('submit').submit();
                    }
                    return false;
                }
            });

            // 1. Gửi mã OTP (AJAX)
            $('#btnSendOTP').click(function () {
                const email = $('#emailInput').val();
                if (!email) {
                    showToast("Vui lòng nhập email trước khi gửi mã.", "error");
                    return;
                }

                const $btn = $(this);
                $btn.prop('disabled', true).text('...');

                $.post('/Account/SendOTP', { email: email }, function (response) {
                    if (response.success) {
                        showToast(response.message, "success");
                        startTimer();
                    } else {
                        showToast(response.message, "error");
                        $btn.prop('disabled', false).text('GỬI MÃ');
                    }
                }).fail(function() {
                    showToast("Lỗi kết nối.", "error");
                    $btn.prop('disabled', false).text('GỬI MÃ');
                });
            });

            // 2. Xác thực mã và Chuyển bước (AJAX)
            $('#btnVerify').click(function () {
                const email = $('#emailInput').val();
                const code = $('#otpInput').val();

                if (!email || !code) {
                    showToast("Vui lòng nhập đủ email và mã xác thực.", "error");
                    return;
                }

                const $btn = $(this);
                $btn.prop('disabled', true).text('ĐANG XÁC THỰC...');

                $.post('/Account/VerifyResetOTP', { email: email, code: code }, function (response) {
                    if (response.success) {
                        $('#step1').fadeOut(300, function () {
                            $('#step2').fadeIn(300);
                        });
                    } else {
                        showToast(response.message, "error");
                        $btn.prop('disabled', false).text('TIẾP THEO');
                    }
                }).fail(function() {
                    showToast("Lỗi hệ thống.", "error");
                    $btn.prop('disabled', false).text('TIẾP THEO');
                });
            });

            function startTimer() {
                let time = 60;
                $('#timer').show();
                $('#btnSendOTP').prop('disabled', true);
                
                countdown = setInterval(function () {
                    time--;
                    $('#countdown').text(time);
                    if (time <= 0) {
                        clearInterval(countdown);
                        $('#timer').hide();
                        $('#btnSendOTP').prop('disabled', false).text('GỬI MÃ');
                    }
                }, 1000);
            }
        });
    </script>
}
