@model TuNhanTamTInh_Ecommerce.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = Loc.T("Quên mật khẩu", "Forgot Password");
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner (Same as Login) -->
        <div class="col-lg-6 d-none d-lg-block p-0">
            <div class="auth-banner">
                <h2>@Loc.T("Khôi phục mật khẩu", "Reset Password")</h2>
                <p>@Loc.T("Đừng lo lắng! Chỉ cần vài bước đơn giản để lấy lại quyền truy cập vào tài khoản của bạn.", "No worries! Just a few simple steps to regain access to your account.")</p>
            </div>
        </div>
        
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <a asp-controller="Account" asp-action="Login" class="back-home"><i class="fa fa-arrow-left"></i> @Loc.T("Quay lại Đăng nhập", "Back to Login")</a>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-5">
                        <h3 class="font-weight-bold auth-title">@Loc.T("Quên Mật Khẩu", "Forgot Password")</h3>
                        <p class="text-muted">@Loc.T("Nhập email để nhận mã xác thực khôi phục", "Enter your email to receive a verification code")</p>
                    </div>
                    
                    <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <!-- Step 1: Nhập Email và nhận mã -->
                        <div id="step1" class="@(ViewData.ModelState.ContainsKey("NewPassword") || ViewData.ModelState.ContainsKey("ConfirmPassword") ? "step-hidden" : "")">
                            <div class="form-group mb-4">
                                <label asp-for="Email" class="font-weight-bold mb-2">@Loc.T("Email của bạn", "Your Email") <span class="text-danger">*</span></label>
                                <input asp-for="Email" id="emailInput" class="form-control auth-input" placeholder="example@gmail.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label class="font-weight-bold mb-2">@Loc.T("Mã xác thực (OTP)", "Verification Code (OTP)")</label>
                                <div class="otp-input-group d-flex">
                                    <input asp-for="VerificationCode" id="otpInput" class="form-control auth-input otp-group-input" placeholder="@Loc.T("Nhập mã 6 số", "Enter 6-digit code")" />
                                    <button type="button" id="btnSendOTP" class="btn btn-primary otp-group-button">@Loc.T("GỬI MÃ", "SEND CODE")</button>
                                </div>
                                <div id="timer" class="small text-muted mt-2 step-hidden">@Loc.T("Gửi lại mã sau", "Resend code in") <span id="countdown">60</span>s</div>
                                <span asp-validation-for="VerificationCode" class="text-danger small"></span>
                            </div>

                            <button type="button" id="btnVerify" class="btn auth-btn w-100 mt-2">@Loc.T("TIẾP THEO", "NEXT")</button>
                        </div>

                        <!-- Step 2: Nhập mã và Mật khẩu mới -->
                        <div id="step2" class="mt-3 @(ViewData.ModelState.ContainsKey("NewPassword") || ViewData.ModelState.ContainsKey("ConfirmPassword") ? "" : "step-hidden")">
                            <div class="alert alert-info text-center small mb-4 auto-hide" role="alert">
                                <i class="fa fa-envelope-open mr-2"></i> @Loc.T("Xác thực thành công. Vui lòng nhập mật khẩu mới.", "Verification successful. Please enter your new password.")
                            </div>
                            
                            <div class="form-group mb-4">
                                <label asp-for="NewPassword" class="font-weight-bold mb-2">@Loc.T("Mật khẩu mới", "New Password") <span class="text-danger">*</span></label>
                                <div class="password-wrapper">
                                    <input asp-for="NewPassword" type="password" class="form-control auth-input" placeholder="@Loc.T("Nhập mật khẩu mới", "Enter new password")" />
                                    <i class="fa fa-eye password-toggle"></i>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="font-weight-bold mb-2">@Loc.T("Xác nhận mật khẩu mới", "Confirm New Password") <span class="text-danger">*</span></label>
                                <div class="password-wrapper">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control auth-input" placeholder="@Loc.T("Xác nhận mật khẩu mới", "Confirm new password")" />
                                    <i class="fa fa-eye password-toggle"></i>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn auth-btn w-100">@Loc.T("ĐỔI MẬT KHẨU", "RESET PASSWORD")</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            let countdown;
            
            // Chặn Enter mặc định của Form
            $('#forgotPasswordForm').on('keyup keypress', function(e) {
                var keyCode = e.keyCode || e.which;
                if (keyCode === 13) { 
                    e.preventDefault();
                    // Nếu đang ở Bước 1, kích hoạt nút Tiếp theo
                    if ($('#step1').is(':visible')) {
                        $('#btnVerify').click();
                    } else {
                        // Nếu đang ở Bước 2, submit form
                        $(this).unbind('submit').submit();
                    }
                    return false;
                }
            });

            // 1. Gửi mã OTP (AJAX)
            $('#btnSendOTP').click(function () {
                const email = $('#emailInput').val();
                if (!email) {
                    showToast("@Html.Raw(Loc.T("Vui lòng nhập email trước khi gửi mã.", "Please enter your email before sending OTP."))", "error");
                    return;
                }

                const $btn = $(this);
                $btn.prop('disabled', true).text('...');

                $.post('/Account/SendOTP', { email: email }, function (response) {
                    if (response.success) {
                        showToast(response.message, "success");
                        startTimer();
                    } else {
                        showToast(response.message, "error");
                        $btn.prop('disabled', false).text('@Html.Raw(Loc.T("GỬI MÃ", "SEND CODE"))');
                    }
                }).fail(function() {
                    showToast("@Html.Raw(Loc.T("Lỗi kết nối.", "Connection error."))", "error");
                    $btn.prop('disabled', false).text('@Html.Raw(Loc.T("GỬI MÃ", "SEND CODE"))');
                });
            });

            // 2. Xác thực mã và Chuyển bước (AJAX)
            $('#btnVerify').click(function () {
                const email = $('#emailInput').val();
                const code = $('#otpInput').val();

                if (!email || !code) {
                    showToast("@Html.Raw(Loc.T("Vui lòng nhập đủ email và mã xác thực.", "Please enter both email and verification code."))", "error");
                    return;
                }

                const $btn = $(this);
                $btn.prop('disabled', true).text('@Html.Raw(Loc.T("ĐANG XÁC THỰC...", "VERIFYING..."))');

                $.post('/Account/VerifyResetOTP', { email: email, code: code }, function (response) {
                    if (response.success) {
                        $('#step1').fadeOut(300, function () {
                            $('#step2').fadeIn(300);
                        });
                    } else {
                        showToast(response.message, "error");
                        $btn.prop('disabled', false).text('@Html.Raw(Loc.T("TIẾP THEO", "NEXT"))');
                    }
                }).fail(function() {
                    showToast("@Html.Raw(Loc.T("Lỗi hệ thống.", "System error."))", "error");
                    $btn.prop('disabled', false).text('@Html.Raw(Loc.T("TIẾP THEO", "NEXT"))');
                });
            });

            function startTimer() {
                let time = 60;
                $('#timer').show();
                $('#btnSendOTP').prop('disabled', true);
                
                countdown = setInterval(function () {
                    time--;
                    $('#countdown').text(time);
                    if (time <= 0) {
                        clearInterval(countdown);
                        $('#timer').hide();
                        $('#btnSendOTP').prop('disabled', false).text('@Html.Raw(Loc.T("GỬI MÃ", "SEND CODE"))');
                    }
                }, 1000);
            }
        });
    </script>
}
