@using TuNhanTamTInh_Ecommerce.Models.ViewModels
@model TuNhanTamTInh_Ecommerce.Models.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = Loc.T("Chỉnh sửa hồ sơ", "Edit Profile");

    var breadcrumb = new BreadcrumbViewModel
    {
        Title = Loc.T("Chỉnh sửa hồ sơ", "Edit Profile"),
        Items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(Loc.T("Trang chủ", "Home"), Url.Action("Index", "Home")),
            new BreadcrumbItem(Loc.T("Hồ sơ cá nhân", "My Profile"), Url.Action("Profile", "Account")),
            new BreadcrumbItem(Loc.T("Chỉnh sửa", "Edit"))
        }
    };
}

<partial name="_Breadcrumb" model="breadcrumb" />

<section class="checkout spad">
    <div class="container">
        <div class="checkout-premium">
            <h4 class="text-center">@Loc.T("Chỉnh sửa hồ sơ cá nhân", "Edit Personal Profile")</h4>
            <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="AccountId" />
                <input type="hidden" asp-for="Image" />

                <div class="row">
                    <div class="col-lg-8 col-md-10 offset-lg-2 offset-md-1">
                        <!-- Avatar Upload Section -->
                        <div class="text-center mb-5">
                            <div class="position-relative d-inline-block">
                                <img id="avatarPreview" src="@Url.Content(Model.Image ?? "~/images/user-default.png")" 
                                     alt="Avatar" class="rounded-circle shadow profile-avatar-preview">
                                <label for="avatarUpload" class="profile-avatar-label">
                                    <i class="fa fa-camera"></i>
                                </label>
                                <input type="file" id="avatarUpload" asp-for="AvatarFile" class="d-none" accept="image/*" onchange="previewImage(this)">
                            </div>
                            <p class="text-muted small mt-2">@Loc.T("Nhấp vào biểu tượng camera để thay đổi ảnh", "Click on camera icon to change avatar")</p>
                            <span asp-validation-for="AvatarFile" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkout__input">
                                    <p>@Loc.T("Họ và Tên", "Full Name")<span>*</span></p>
                                    <input asp-for="FullName" placeholder="@Loc.T("Nhập họ và tên...", "Enter full name...")">
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Email<span>*</span></p>
                                    <input asp-for="Email" placeholder="example@email.com">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>@Loc.T("Số điện thoại", "Phone Number")</p>
                                    <input asp-for="PhoneNumber" placeholder="0123 456 789">
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="checkout__input">
                            <p>@Loc.T("Địa chỉ", "Address")</p>
                            <input asp-for="Address" placeholder="@Loc.T("Nhập địa chỉ của bạn...", "Enter your address...")">
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>@Loc.T("Ngày sinh", "Birthdate")</p>
                                    <input asp-for="BirthDate" type="date">
                                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>@Loc.T("Giới tính", "Gender")</p>
                                    <select asp-for="Gender" class="w-100 no-nice-select form-control custom-gender-select">
                                        <option value="True">@Loc.T("Nam", "Male")</option>
                                        <option value="False">@Loc.T("Nữ", "Female")</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 text-center d-flex flex-column align-items-center">
                            <button type="submit" class="site-btn rounded-pill px-5 text-uppercase mb-3">
                                <i class="fa fa-save mr-2"></i> @Loc.T("Lưu thay đổi", "Save Changes")
                            </button>
                            <a asp-action="Profile" class="text-muted no-decoration"><i class="fa fa-arrow-left mr-2"></i> @Loc.T("Quay lại hồ sơ", "Back to Profile")</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Vô hiệu hóa nice-select cho ô chọn giới tính
            $('.no-nice-select').niceSelect('destroy');

            // AJAX Edit Profile
            $('form[asp-action="EditProfile"]').on('submit', function(e) {
                e.preventDefault();
                const form = $(this);
                const formData = new FormData(this);

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => {
                                window.location.href = '@Url.Action("Profile", "Account")';
                            }, 1500);
                        } else {
                            showToast(response.message, 'error');
                        }
                    },
                    error: function() {
                        showToast("@Loc.T("Đã có lỗi xảy ra khi cập nhật hồ sơ.", "An error occurred while updating profile.")", "error");
                    }
                });
            });
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#avatarPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
