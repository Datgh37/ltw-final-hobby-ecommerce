@model TuNhanTamTInh_Ecommerce.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = Loc.T("Đăng ký", "Register");
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner (Now visual on the right) -->
        <div class="col-lg-6 d-none d-lg-block p-0 order-2">
            <div class="auth-banner">
                <h2>@Loc.T("Tạo Tài Khoản Mới", "Create New Account")</h2>
                <p>@Loc.T("Trở thành thành viên của cộng đồng đam mê mô hình. Nhận ngay những ưu đãi đặc biệt và cập nhật sản phẩm mới nhất.", "Join our model kit enthusiast community. Receive special offers and stay updated on the latest products.")</p>
            </div>
        </div>
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <div class="auth-header-actions">
                <partial name="_LanguageSelector" view-data='@(new ViewDataDictionary(ViewData) { { "IsAuth", true } })' />
                <span class="auth-divider">|</span>
                <a asp-controller="Home" asp-action="Index" class="back-home-link"><i class="fa fa-home"></i> @Loc.T("Trang chủ", "Home")</a>
            </div>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-4">
                        <h3 class="font-weight-bold auth-title">@Loc.T("Đăng Ký", "Register")</h3>
                        <p class="text-muted">@Loc.T("Vui lòng điền thông tin để tạo tài khoản", "Please enter your information to register")</p>
                    </div>
                    
                    <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" id="registerForm">
                        <!-- Thẻ ẩn hiển thị lỗi tổng quan -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger @(ViewData.ModelState.IsValid ? "step-hidden" : "")"></div>
                        
                        <!-- Step 1: Account Info -->
                        <div id="step1" class="@(ViewData.ModelState.ContainsKey("VerificationCode") ? "step-hidden" : "")">
                            <div class="form-group mb-3">
                                <label asp-for="Username" class="font-weight-bold mb-2">@Loc.T("Tên đăng nhập", "Username") <span class="text-danger">*</span></label>
                                <input asp-for="Username" class="form-control auth-input" placeholder="@Loc.T("Nhập tên đăng nhập...", "Enter username...")" />
                                <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="FullName" class="font-weight-bold mb-2">@Loc.T("Họ và Tên", "Full Name") <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control auth-input" placeholder="@Loc.T("Nhập họ và tên...", "Enter full name...")" />
                                <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="font-weight-bold mb-2">@Loc.T("Email", "Email Address") <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control auth-input" placeholder="@Loc.T("Nhập địa chỉ email...", "Enter email address...")" />
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 form-group mb-3">
                                    <label asp-for="Password" class="font-weight-bold mb-2">@Loc.T("Mật khẩu", "Password") <span class="text-danger">*</span></label>
                                    <div class="password-wrapper">
                                        <input asp-for="Password" class="form-control auth-input" placeholder="@Loc.T("Nhập mật khẩu...", "Enter password...")" type="password" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="ConfirmPassword" class="font-weight-bold mb-2">@Loc.T("Xác nhận", "Confirm") <span class="text-danger">*</span></label>
                                    <div class="password-wrapper">
                                        <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="@Loc.T("Nhập lại...", "Confirm password...")" type="password" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <button type="button" class="btn auth-btn w-100" id="btnNextStep">@Loc.T("TIẾP THEO", "NEXT")</button>
                        </div>

                        <!-- Step 2: OTP Verification -->
                        <div id="step2" class="mt-3 @(ViewData.ModelState.ContainsKey("VerificationCode") ? "" : "step-hidden")">
                            <div class="alert alert-info text-center small mb-4 auto-hide" role="alert">
                                <i class="fa fa-envelope-open mr-2"></i> @Loc.T("Chúng tôi vừa gửi mã xác thực đến Email của bạn.", "We have sent a verification code to your email.")
                            </div>
                            <div class="form-group mb-4">
                                <label asp-for="VerificationCode" class="font-weight-bold mb-2 text-center w-100">@Loc.T("Mã xác thực (OTP)", "Verification Code (OTP)") <span class="text-danger">*</span></label>
                                <input asp-for="VerificationCode" class="form-control auth-input text-center otp-input-aesthetic" placeholder="X X X X X X" />
                                <span asp-validation-for="VerificationCode" class="text-danger small text-center d-block"></span>
                            </div>
                            <button type="submit" class="btn auth-btn w-100" id="btnRegister">@Loc.T("HOÀN TẤT ĐĂNG KÝ", "COMPLETE REGISTER")</button>
                            
                            <div class="text-center mt-3">
                                <button type="button" id="btnResendCode" class="btn btn-link text-muted small no-decoration">@Loc.T("Chưa nhận được mã? Gửi lại", "Didn't receive the code? Resend")</button>
                            </div>

                            <button type="button" onclick="location.reload();" class="btn btn-link w-100 mt-2 text-muted small">@Loc.T("Quay lại sửa thông tin", "Back to edit details")</button>
                        </div>
                        
                        <div class="text-center mt-4">
                            <p class="text-muted auth-footer-text">@Loc.T("Đã có tài khoản?", "Already have an account?") <a asp-controller="Account" asp-action="Login" class="auth-link">@Loc.T("Đăng nhập ngay", "Login now")</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            var countdownTimer;

            function startCountdown(seconds) {
                var $btn = $('#btnResendCode');
                $btn.prop('disabled', true);
                
                var remaining = seconds;
                $btn.text('@Html.Raw(Loc.T("Gửi lại sau (", "Resend in ("))' + remaining + 's)');
                
                countdownTimer = setInterval(function() {
                    remaining--;
                    if (remaining <= 0) {
                        clearInterval(countdownTimer);
                        $btn.prop('disabled', false).text('@Html.Raw(Loc.T("Gửi lại mã", "Resend Code"))');
                    } else {
                        $btn.text('@Html.Raw(Loc.T("Gửi lại sau (", "Resend in ("))' + remaining + 's)');
                    }
                }, 1000);
            }

            // 1. AJAX Gửi mã OTP Đăng ký
            function sendOTP() {
                var username = $('#Username').val();
                var email = $('#Email').val();
                if(!email || !username) {
                    showToast("@Html.Raw(Loc.T("Vui lòng nhập tên đăng nhập và email trước khi nhận mã.", "Please enter username and email before requesting OTP."))", 'error');
                    return;
                }

                var $btnNext = $('#btnNextStep');
                var $btnResend = $('#btnResendCode');
                
                $btnNext.prop('disabled', true).text('@Html.Raw(Loc.T("Đang gửi...", "Sending..."))');
                $btnResend.prop('disabled', true).text('@Html.Raw(Loc.T("Đang gửi...", "Sending..."))');

                $.ajax({
                    url: '/Account/SendRegisterOTP',
                    type: 'POST',
                    data: { username: username, email: email },
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            $('#step1').fadeOut(300, function() {
                                $('#step2').fadeIn(300);
                                startCountdown(60);
                            });
                        } else {
                            showToast(response.message, 'error');
                            $btnNext.prop('disabled', false).text('@Html.Raw(Loc.T("TIẾP THEO", "NEXT"))');
                            $btnResend.prop('disabled', false).text('@Html.Raw(Loc.T("Gửi lại", "Resend"))');
                        }
                    },
                    error: function() {
                        showToast("@Html.Raw(Loc.T("Có lỗi xảy ra khi kết nối server.", "An error occurred while connecting to the server."))", 'error');
                        $btnNext.prop('disabled', false).text('@Html.Raw(Loc.T("TIẾP THEO", "NEXT"))');
                        $btnResend.prop('disabled', false).text('@Html.Raw(Loc.T("Gửi lại", "Resend"))');
                    }
                });
            }

            $('#btnNextStep').click(function() {
                var username = $('#Username').val();
                var email = $('#Email').val();
                var password = $('#Password').val();
                var confirm = $('#ConfirmPassword').val();

                if(!username || !email || !password || password !== confirm) {
                    showToast("@Html.Raw(Loc.T("Vui lòng điền đầy đủ và chính xác thông tin trước khi nhận mã OTP.", "Please enter all information correctly before requesting OTP."))", 'error');
                    return;
                }
                sendOTP();
            });

            $('#btnResendCode').click(function() {
                sendOTP();
            });

            // 2. AJAX Đăng ký cuối cùng
            $('#registerForm').submit(function(e) {
                e.preventDefault(); // Chặn submit mặc định

                // Nếu đang ở bước 1 mà nhấn submit (thường là qua phím Enter)
                if ($('#step1').is(':visible')) {
                    $('#btnNextStep').click();
                    return;
                }

                var $btn = $('#btnRegister');
                $btn.prop('disabled', true).text('@Html.Raw(Loc.T("Đang xử lý...", "Processing..."))');

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => { window.location.href = response.returnUrl || '/'; }, 1000); 
                        } else {
                            showToast(response.message, 'error');
                            $btn.prop('disabled', false).text('@Html.Raw(Loc.T("HOÀN TẤT ĐĂNG KÝ", "COMPLETE REGISTER"))');
                        }
                    },
                    error: function() {
                        showToast("@Html.Raw(Loc.T("Có lỗi xảy ra khi kết nối server.", "An error occurred while connecting to the server."))", 'error');
                        $btn.prop('disabled', false).text('@Html.Raw(Loc.T("HOÀN TẤT ĐĂNG KÝ", "COMPLETE REGISTER"))');
                    }
                });
            });

            // 3. Chặn Enter để không submit nhầm (đã được handle trong submit phía trên)
        });
    </script>
}
