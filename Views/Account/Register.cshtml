@model TuNhanTamTInh_Ecommerce.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_LayoutAuth";
}

<section class="auth-wrapper container-fluid p-0">
    <div class="row g-0">
        <!-- Left Banner (Now visual on the right) -->
        <div class="col-lg-6 d-none d-lg-block p-0 order-2">
            <div class="auth-banner">
                <h2>Tạo Tài Khoản Mới</h2>
                <p>Trở thành thành viên của cộng đồng đam mê mô hình. Nhận ngay những ưu đãi đặc biệt và cập nhật sản phẩm mới nhất.</p>
            </div>
        </div>
        <!-- Right Form -->
        <div class="col-lg-6 p-0 position-relative">
            <a asp-controller="Home" asp-action="Index" class="back-home"><i class="fa fa-home"></i> Trang chủ</a>
            <div class="auth-form-wrapper">
                <div class="auth-form-container">
                    <div class="text-center mb-4">
                        <h3 class="font-weight-bold auth-title">Đăng Ký</h3>
                        <p class="text-muted">Vui lòng điền thông tin để tạo tài khoản</p>
                    </div>
                    
                    <form asp-action="Register" method="post" id="registerForm">
                        <!-- Thẻ ẩn hiển thị lỗi tổng quan -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger @(ViewData.ModelState.IsValid ? "step-hidden" : "")"></div>
                        
                        <!-- Step 1: Account Info -->
                        <div id="step1" class="@(ViewData.ModelState.ContainsKey("VerificationCode") ? "step-hidden" : "")">
                            <div class="form-group mb-3">
                                <label asp-for="Username" class="font-weight-bold mb-2">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input asp-for="Username" class="form-control auth-input" placeholder="Nhập tên đăng nhập..." />
                                <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="FullName" class="font-weight-bold mb-2">Họ và Tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control auth-input" placeholder="Nhập họ và tên..." />
                                <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Email" class="font-weight-bold mb-2">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control auth-input" placeholder="Nhập địa chỉ email..." />
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 form-group mb-3">
                                    <label asp-for="Password" class="font-weight-bold mb-2">Mật khẩu <span class="text-danger">*</span></label>
                                    <div class="password-wrapper">
                                        <input asp-for="Password" class="form-control auth-input" placeholder="Nhập mật khẩu..." type="password" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="ConfirmPassword" class="font-weight-bold mb-2">Xác nhận <span class="text-danger">*</span></label>
                                    <div class="password-wrapper">
                                        <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="Nhập lại..." type="password" />
                                        <i class="fa fa-eye password-toggle"></i>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <button type="button" class="btn auth-btn w-100" id="btnNextStep">TIẾP THEO</button>
                        </div>

                        <!-- Step 2: OTP Verification -->
                        <div id="step2" class="mt-3 @(ViewData.ModelState.ContainsKey("VerificationCode") ? "" : "step-hidden")">
                            <div class="alert alert-info text-center small mb-4 auto-hide" role="alert">
                                <i class="fa fa-envelope-open mr-2"></i> Chúng tôi vừa gửi mã xác thực đến Email của bạn.
                            </div>
                            <div class="form-group mb-4">
                                <label asp-for="VerificationCode" class="font-weight-bold mb-2 text-center w-100">Mã xác thực (OTP) <span class="text-danger">*</span></label>
                                <input asp-for="VerificationCode" class="form-control auth-input text-center otp-input-aesthetic" placeholder="X X X X X X" />
                                <span asp-validation-for="VerificationCode" class="text-danger small text-center d-block"></span>
                            </div>
                            <button type="submit" class="btn auth-btn w-100" id="btnRegister">HOÀN TẤT ĐĂNG KÝ</button>
                            
                            <div class="text-center mt-3">
                                <button type="button" id="btnResendCode" class="btn btn-link text-muted small no-decoration">Chưa nhận được mã? Gửi lại</button>
                            </div>

                            <button type="button" onclick="location.reload();" class="btn btn-link w-100 mt-2 text-muted small">Quay lại sửa thông tin</button>
                        </div>
                        
                        <div class="text-center mt-4">
                            <p class="text-muted auth-footer-text">Đã có tài khoản? <a asp-controller="Account" asp-action="Login" class="auth-link">Đăng nhập ngay</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            var countdownTimer;

            function startCountdown(seconds) {
                var $btn = $('#btnResendCode');
                $btn.prop('disabled', true);
                
                var remaining = seconds;
                $btn.text('Gửi lại sau (' + remaining + 's)');
                
                countdownTimer = setInterval(function() {
                    remaining--;
                    if (remaining <= 0) {
                        clearInterval(countdownTimer);
                        $btn.prop('disabled', false).text('Gửi lại mã');
                    } else {
                        $btn.text('Gửi lại sau (' + remaining + 's)');
                    }
                }, 1000);
            }

            // 1. AJAX Gửi mã OTP Đăng ký
            function sendOTP() {
                var username = $('#Username').val();
                var email = $('#Email').val();
                if(!email || !username) {
                    showToast("Vui lòng nhập tên đăng nhập và email trước khi nhận mã.", 'error');
                    return;
                }

                var $btnNext = $('#btnNextStep');
                var $btnResend = $('#btnResendCode');
                
                $btnNext.prop('disabled', true).text('Đang gửi...');
                $btnResend.prop('disabled', true).text('Đang gửi...');

                $.ajax({
                    url: '/Account/SendRegisterOTP',
                    type: 'POST',
                    data: { username: username, email: email },
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            $('#step1').fadeOut(300, function() {
                                $('#step2').fadeIn(300);
                                startCountdown(60);
                            });
                        } else {
                            showToast(response.message, 'error');
                            $btnNext.prop('disabled', false).text('TIẾP THEO');
                            $btnResend.prop('disabled', false).text('Gửi lại');
                        }
                    },
                    error: function() {
                        showToast("Có lỗi xảy ra khi kết nối server.", 'error');
                        $btnNext.prop('disabled', false).text('TIẾP THEO');
                        $btnResend.prop('disabled', false).text('Gửi lại');
                    }
                });
            }

            $('#btnNextStep').click(function() {
                var username = $('#Username').val();
                var email = $('#Email').val();
                var password = $('#Password').val();
                var confirm = $('#ConfirmPassword').val();

                if(!username || !email || !password || password !== confirm) {
                    showToast("Vui lòng điền đầy đủ và chính xác thông tin trước khi nhận mã OTP.", 'error');
                    return;
                }
                sendOTP();
            });

            $('#btnResendCode').click(function() {
                sendOTP();
            });

            // 2. AJAX Đăng ký cuối cùng
            $('#registerForm').submit(function(e) {
                e.preventDefault(); // Chặn submit mặc định

                // Nếu đang ở bước 1 mà nhấn submit (thường là qua phím Enter)
                if ($('#step1').is(':visible')) {
                    $('#btnNextStep').click();
                    return;
                }

                var $btn = $('#btnRegister');
                $btn.prop('disabled', true).text('Đang xử lý...');

                $.ajax({
                    url: '/Account/Register',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => { window.location.href = '/'; }, 1000); 
                        } else {
                            showToast(response.message, 'error');
                            $btn.prop('disabled', false).text('HOÀN TẤT ĐĂNG KÝ');
                        }
                    },
                    error: function() {
                        showToast("Có lỗi xảy ra khi kết nối server.", 'error');
                        $btn.prop('disabled', false).text('HOÀN TẤT ĐĂNG KÝ');
                    }
                });
            });

            // 3. Chặn Enter để không submit nhầm (đã được handle trong submit phía trên)
        });
    </script>
}
