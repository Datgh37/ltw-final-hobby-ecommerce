@model TuNhanTamTInh_Ecommerce.Models.Category

@{
    ViewData["Title"] = "Xóa Danh mục";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span>/</span>
                <a asp-controller="Categories" asp-action="Index">Danh mục</a>
                <span>/</span>
                <span>Xóa</span>
            </div>
            <h1><i class="fa fa-trash"></i> Xóa Danh mục</h1>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <!-- Warning -->
                    <div class="crud-delete-warning">
                        <i class="fa fa-exclamation-triangle"></i>
                        <span>Bạn có chắc chắn muốn xóa danh mục này không? Hành động này không thể hoàn tác.</span>
                    </div>

                    <h3 class="crud-card__title">
                        <i class="fa fa-th-list"></i> @Model.CategoryName
                    </h3>
                    <dl class="crud-detail-list">
                        <dt>Tên danh mục</dt>
                        <dd>@Html.DisplayFor(model => model.CategoryName)</dd>
                        <dt>Slug</dt>
                        <dd><code>@Html.DisplayFor(model => model.CategorySlug)</code></dd>
                        <dt>Hình ảnh</dt>
                        <dd>@Html.DisplayFor(model => model.Image)</dd>
                    </dl>

                    <form asp-controller="Admin" asp-action="CategoryDelete">
                        <input type="hidden" asp-for="CategoryId" />
                        <div class="crud-btn-group">
                            <button type="submit" class="crud-btn crud-btn--danger">
                                <i class="fa fa-trash"></i> Xác nhận xóa
                            </button>
                            <a asp-controller="Admin" asp-action="Categories" class="crud-btn crud-btn--secondary">
                                <i class="fa fa-arrow-left"></i> Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
