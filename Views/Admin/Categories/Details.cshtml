@model TuNhanTamTInh_Ecommerce.Models.Category

@{
    ViewData["Title"] = "Chi tiết Danh mục";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span>/</span>
                <a asp-controller="Categories" asp-action="Index">Danh mục</a>
                <span>/</span>
                <span>Chi tiết</span>
            </div>
            <h1><i class="fa fa-info-circle"></i> Chi tiết Danh mục</h1>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <h3 class="crud-card__title">
                        <i class="fa fa-th-list"></i> @Model.CategoryName
                    </h3>
                    <dl class="crud-detail-list">
                        <dt>Tên danh mục</dt>
                        <dd>@Html.DisplayFor(model => model.CategoryName)</dd>
                        <dt>Slug</dt>
                        <dd><code>@Html.DisplayFor(model => model.CategorySlug)</code></dd>
                        <dt>Hình ảnh</dt>
                        <dd>
                             @if (!string.IsNullOrEmpty(Model.Image))
                             {
                                 <img src="@Url.Content(Model.Image)" alt="@Model.CategoryName" class="crud-category-details-img" />
                             }
                             else
                             {
                                 <span style="color:#ccc;">Không có hình ảnh</span>
                             }
                        </dd>
                    </dl>
                    <div class="crud-btn-group">
                        <a asp-controller="Admin" asp-action="CategoryEdit" asp-route-id="@Model.CategoryId" class="crud-btn crud-btn--primary">
                            <i class="fa fa-pencil"></i> Chỉnh sửa
                        </a>
                        <a asp-controller="Admin" asp-action="Categories" class="crud-btn crud-btn--secondary">
                            <i class="fa fa-arrow-left"></i> Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
