@model TuNhanTamTInh_Ecommerce.Models.Order

@{
    ViewData["Title"] = "Chi tiết Đơn hàng #" + Model.OrderId;
}

<section class="crud-page">
    <div class="container">
        <!-- Page Header -->
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span>/</span>
                <a asp-action="Orders">Đơn hàng</a>
                <span>/</span>
                <span>Chi tiết</span>
            </div>
            <h1><i class="fa fa-info-circle"></i> Chi tiết Đơn hàng #@Model.OrderId</h1>
            <p>Xem thông tin chi tiết về khách hàng, sản phẩm và thanh toán.</p>
        </div>

        <div class="crud-card">
            <div class="crud-card__title">
                <i class="fa fa-list"></i> Thông tin chung
            </div>
            
            <dl class="crud-detail-list">
                <dt>Mã đơn hàng</dt>
                <dd>#@Model.OrderId</dd>

                <dt>Khách hàng</dt>
                <dd>@Model.FullName</dd>

                <dt>Tài khoản / Email</dt>
                <dd>@Model.Account?.Email</dd>

                <dt>Số điện thoại</dt>
                <dd>@Model.PhoneNumber</dd>

                <dt>Địa chỉ giao hàng</dt>
                <dd>@Model.Address</dd>

                <dt>Ngày đặt</dt>
                <dd>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                <dt>Phương thức thanh toán</dt>
                <dd>@Model.PaymentMethod</dd>

                <dt>Trạng thái thanh toán</dt>
                <dd>
                    <span class="crud-badge @(Model.IsPaid ? "crud-badge--green" : "crud-badge--yellow")">
                        @(Model.IsPaid ? "Đã thanh toán" : "Chưa thanh toán")
                    </span>
                </dd>

                <dt>Trạng thái đơn hàng</dt>
                <dd>
                    @{
                        string badgeClass = Model.StatusId switch
                        {
                            0 => "crud-badge--yellow", // Pending
                            1 => "crud-badge--blue",   // Preparing
                            2 => "crud-badge--blue",   // Shipping
                            3 => "crud-badge--green",  // Delivered
                            4 => "crud-badge--red",    // Cancelled
                            _ => ""
                        };
                    }
                    <span class="crud-badge @badgeClass">@Model.Status?.StatusName</span>
                </dd>
            </dl>

            <div class="crud-card__title crud-card__title--mt-40">
                <i class="fa fa-cubes"></i> Sản phẩm trong đơn
            </div>

            <div class="crud-table-wrapper">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal subtotal = 0;
                        }
                        @foreach (var item in Model.OrderDetails)
                        {
                            decimal itemTotal = item.UnitPrice * item.Quantity;
                            subtotal += itemTotal;
                            <tr>
                                <td>
                                    <strong>@item.Product?.ProductName</strong>
                                </td>
                                <td>@item.UnitPrice.ToString("N0") ₫</td>
                                <td>@item.Quantity</td>
                                <td>@itemTotal.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="crud-table-footer-cell crud-table-footer-cell--right crud-table-footer-cell--border-top">Tổng tạm tính:</td>
                            <td class="crud-table-footer-cell crud-table-footer-cell--border-top">@subtotal.ToString("N0") ₫</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="crud-table-footer-cell crud-table-footer-cell--right">Phí vận chuyển:</td>
                            <td class="crud-table-footer-cell">@Model.ShippingFee.ToString("N0") ₫</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="crud-table-footer-cell crud-table-footer-cell--right crud-table-footer-cell--total">Tổng cộng:</td>
                            <td class="crud-table-footer-cell crud-table-footer-cell--total">
                                @((subtotal + Model.ShippingFee).ToString("N0")) ₫
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="crud-btn-group mt-4">
                <a asp-action="OrderEdit" asp-route-id="@Model.OrderId" class="crud-btn crud-btn--yellow">
                    <i class="fa fa-pencil"></i> Cập nhật trạng thái
                </a>
                <a asp-action="Orders" class="crud-btn crud-btn--secondary">
                    <i class="fa fa-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</section>
