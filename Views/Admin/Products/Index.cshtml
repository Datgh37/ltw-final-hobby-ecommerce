@model IEnumerable<TuNhanTamTInh_Ecommerce.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<section class="crud-page">
    <div class="container">
        <!-- Page Header -->
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span>/</span>
                <span>Sản phẩm</span>
            </div>
            <h1><i class="fa fa-cube"></i> Quản lý Sản phẩm</h1>
            <p>Quản lý danh sách tất cả sản phẩm trong cửa hàng của bạn.</p>
        </div>

        <!-- Create Button -->
        <a asp-controller="Admin" asp-action="ProductCreate" class="crud-btn crud-btn--create">
            <i class="fa fa-plus"></i> Thêm Sản phẩm Mới
        </a>

        <!-- Table Card -->
        <div class="crud-card">
            <table class="crud-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Giảm giá</th>
                        <th>Tồn kho</th>
                        <th>Danh mục</th>
                        <th>Series</th>
                        <th>Nhà cung cấp</th>
                        <th>Lượt xem</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int stt = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(stt++)</td>
                            <td>
                                <strong>@Html.DisplayFor(modelItem => item.ProductName)</strong>
                                @if (!string.IsNullOrEmpty(item.ProductSlug))
                                {
                                    <br /><small style="color:#999;">@item.ProductSlug</small>
                                }
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.UnitPrice)</td>
                            <td>
                                @if (item.Discount > 0)
                                {
                                    <span class="crud-badge crud-badge--green">@(item.Discount * 100)%</span>
                                }
                                else
                                {
                                    <span style="color:#ccc;">—</span>
                                }
                            </td>
                            <td>
                                @if (item.StockQuantity > 0)
                                {
                                    <span class="crud-badge crud-badge--green">@item.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="crud-badge crud-badge--red">Hết hàng</span>
                                }
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Category.CategoryId)</td>
                            <td>@Html.DisplayFor(modelItem => item.Series.SeriesId)</td>
                            <td>@Html.DisplayFor(modelItem => item.Supplier.SupplierId)</td>
                            <td>@Html.DisplayFor(modelItem => item.ViewCount)</td>
                            <td class="crud-actions">
                                <a asp-controller="Admin" asp-action="ProductEdit" asp-route-id="@item.ProductId" class="crud-btn--edit" title="Sửa">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <a asp-controller="Admin" asp-action="ProductDetails" asp-route-id="@item.ProductId" class="crud-btn--detail" title="Chi tiết">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a asp-controller="Admin" asp-action="ProductDelete" asp-route-id="@item.ProductId" class="crud-btn--delete" title="Xóa">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
