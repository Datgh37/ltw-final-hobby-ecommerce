@{
    ViewData["Title"] = Loc.T("Liên hệ", "Contact Us");
}

<!-- Contact Section Begin -->
<section class="contact spad">
    <div class="container">

        <div class="row mb-5">
            <div class="col-lg-4 col-md-6 col-sm-6">
                <div class="contact__widget text-center">
                    <span class="icon_phone"></span>
                    <h4>@Loc.T("Điện thoại", "Phone")</h4>
                    <p>+84 912 202 605</p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 col-sm-6">
                <div class="contact__widget text-center">
                    <span class="icon_pin_alt"></span>
                    <h4>@Loc.T("Địa chỉ", "Address")</h4>
                    <p>@Loc.T("Nguyễn Khuyến, KP5, P. Trảng Dài, Đồng Nai", "Nguyen Khuyen, Ward 5, Trang Dai, Dong Nai")</p>
                </div>
            </div>

            <div class="col-lg-4 col-md-12 col-sm-12">
                <div class="contact__widget text-center">
                    <span class="icon_mail_alt"></span>
                    <h4>Email</h4>
                    <p>support@tunhantamtinh.com</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="contact__form">
                    <div class="section-title">
                        <h2>@Loc.T("Gửi liên hệ", "Send Message")</h2>
                    </div>

                    <form>
                        <div class="row">
                            <div class="col-lg-6 col-md-6">
                                <input type="text" placeholder="@Loc.T("Họ và tên", "Your Name")">
                            </div>

                            <div class="col-lg-6 col-md-6">
                                <input type="email" placeholder="Email">
                            </div>

                            <div class="col-lg-12 text-message">
                                <textarea placeholder="@Loc.T("Nội dung liên hệ", "Your Message")"></textarea>
                                <button type="submit" class="site-btn">
                                    @Loc.T("Gửi liên hệ", "Send Message")
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-6 col-md-6">
                <div class="contact__map">
                    <iframe
                        src="https://www.google.com/maps?q=Nguyễn+Khuyến,+Khu+phố+5,+Trảng+Dài,+Biên+Hòa,+Đồng+Nai&output=embed"
                        height="450"
                        style="border:0; width:100%; border-radius: 10px;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Contact Section End -->