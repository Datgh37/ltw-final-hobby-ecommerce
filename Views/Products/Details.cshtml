@using TuNhanTamTInh_Ecommerce.Models.ViewModels
@model TuNhanTamTInh_Ecommerce.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
    var breadcrumb = new BreadcrumbViewModel
    {
        Title = Loc.T("Chi tiết sản phẩm", "Product Details"),
        Items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(Loc.T("Trang chủ", "Home"), Url.Action("Index", "Home")),
            new BreadcrumbItem(Loc.T("Sản phẩm", "Products"), Url.Action("Index", "Products", new { categoryId = Model.CategoryId })),
            new BreadcrumbItem(Model.ProductName)
        }
    };
    
    // Lấy ảnh chính hoặc ảnh đầu tiên
    var primaryImage = Model.ProductImages?.FirstOrDefault(pi => pi.IsPrimary)?.ImageUrl 
                    ?? Model.ProductImages?.FirstOrDefault()?.ImageUrl 
                    ?? "~/images/Others/product-1.jpg";
                    
    var finalPrice = Model.UnitPrice;
    if (Model.Discount > 0)
    {
        finalPrice = Model.UnitPrice * (1m - (decimal)Model.Discount / 100m);
    }
}
@await Component.InvokeAsync("HeroSection");

<!-- Breadcrumb Section Begin -->
<partial name="_Breadcrumb" model="breadcrumb" />
<!-- Breadcrumb Section End -->
<!-- Product Details Section Begin -->
<section class="product-details spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="product__details__pic @(Model.StockQuantity <= 0 ? "is-sold-out" : "")">
                    <div class="product__details__pic__item">
                        @if (Model.StockQuantity <= 0)
                        {
                            <div class="sold-out-overlay">
                                <span class="sold-out-text">@Loc.T("Hết hàng", "Out of stock")</span>
                            </div>
                        }
                        <img class="product__details__pic__item--large product__details__main-img"
                             src="@Url.Content(primaryImage)" alt="@Model.ProductName">
                    </div>
                    @if (Model.ProductImages != null && Model.ProductImages.Count > 1)
                    {
                        <div class="product__details__pic__slider owl-carousel">
                            @foreach (var img in Model.ProductImages)
                            {
                                <img class="product__details__thumb-img" data-imgbigurl="@Url.Content(img.ImageUrl)"
                                     src="@Url.Content(img.ImageUrl)" alt="@Model.ProductName">
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="product__details__text">
                    <h3>@Model.ProductName</h3>
                    @if (Model.Series != null)
                    {
                        <h5 class="text-muted mb-2">Series: @Model.Series.SeriesName</h5>
                    }
                    <div class="product__details__rating">
                        <i class="fa fa-star"></i>
                        <i class="fa fa-star"></i>
                        <i class="fa fa-star"></i>
                        <i class="fa fa-star"></i>
                        <i class="fa fa-star-half-o"></i>
                        <span>(@(Model.Reviews?.Count ?? 0) @Loc.T("đánh giá", "reviews"))</span>
                    </div>
                    
                    @if (Model.Discount > 0)
                    {
                        <div class="product__details__price">
                            @finalPrice.ToString("N0")₫
                            <span class="text-muted text-decoration-line-through fs-5 ml-2" style="font-size: 18px; color: #b2b2b2; margin-left: 10px;">@Model.UnitPrice.ToString("N0")₫</span>
                            <span class="badge bg-danger ms-2">-@(Model.Discount *100)%</span>
                        </div>
                    }
                    else
                    {
                        <div class="product__details__price">@Model.UnitPrice.ToString("N0")₫</div>
                    }
                    
                    <p>
                        @(string.IsNullOrWhiteSpace(Model.Description) ? Loc.T("Chưa có mô tả cho sản phẩm này.", "No description available for this product.") : Model.Description)
                    </p>
                    <div class="product__details__quantity">
                        <div class="quantity">
                            <div class="pro-qty @(Model.StockQuantity <= 0 ? "qty-disabled" : "")" data-max-stock="@Model.StockQuantity">
                                <input type="text" value="@(Model.StockQuantity > 0 ? "1" : "0")" id="productQuantity" readonly>
                            </div>
                        </div>
                    </div>
                    @if (Model.StockQuantity > 0)
                    {
                        <a href="#" class="primary-btn add-to-cart" data-product-id="@Model.ProductId">@Loc.T("THÊM VÀO GIỎ", "ADD TO CART")</a>
                    }
                    else
                    {
                        <a href="javascript:void(0)" class="primary-btn btn-disabled" style="cursor: not-allowed;">@Loc.T("HẾT HÀNG", "OUT OF STOCK")</a>
                    }
                    <a href="javascript:void(0)" class="heart-icon toggle-favorite" data-product-id="@Model.ProductId" id="fav-btn-@Model.ProductId">
                        <span class="@((bool)ViewBag.IsFavorite ? "icon_heart" : "icon_heart_alt")"></span>
                    </a>
                    <ul>
                        <li><b>@Loc.T("Tình trạng", "Availability")</b> <span class="@(Model.StockQuantity > 0 ? "text-success" : "text-danger")">@(Model.StockQuantity > 0 ? $"{Loc.T("Còn hàng", "In Stock")} ({Model.StockQuantity})" : Loc.T("Hết hàng", "Out of Stock"))</span></li>
                        <li><b>@Loc.T("Danh mục", "Category")</b> <span>@Model.Category?.CategoryName</span></li>
                        @if (Model.Supplier != null)
                        {
                            <li><b>@Loc.T("Hãng sản xuất", "Manufacturer")</b> <span>@Model.Supplier.CompanyName</span></li>
                        }
                        <li>
                            <b>@Loc.T("Chia sẻ", "Share")</b>
                            <div class="share">
                                <a href="#"><i class="fa fa-facebook"></i></a>
                                <a href="#"><i class="fa fa-twitter"></i></a>
                                <a href="#"><i class="fa fa-instagram"></i></a>
                                <a href="#"><i class="fa fa-pinterest"></i></a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
