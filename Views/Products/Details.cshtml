</section>
<!-- Product Details Section End -->
<!-- Related Product Section Begin -->
@if (ViewBag.RelatedProducts != null && ViewBag.RelatedProducts.Count > 0)
{
    <section class="related-product">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="section-title related__product__title">
                        <h2>@Loc.T("Sản phẩm liên quan", "Related Products")</h2>
                    </div>
                </div>
            </div>
            <div class="row">
                @foreach (var item in (IEnumerable<TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel>)ViewBag.RelatedProducts)
                {
                    <partial name="_ProductCard" model="item" view-data='new ViewDataDictionary(ViewData) { { "ColClass", "col-lg-3 col-md-4 col-sm-6" } }' />
                }
            </div>
        </div>
    </section>
}

<!-- Related Product Section End -->