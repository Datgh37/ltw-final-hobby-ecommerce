@model TuNhanTamTInh_Ecommerce.DTOs.ProductUpdateInfoDTO

@{
    ViewData["Title"] = "Create Product";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-controller="Products" asp-action="Index">Products</a>
                <span>/</span>
                <span>Create</span>
            </div>
            <h1><i class="fa fa-plus-circle"></i> Create New Product</h1>
            <p>Fill in the details below to add a new product to your store.</p>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <h3 class="crud-card__title">
                        <i class="fa fa-cube"></i> Product Information
                    </h3>
                    <form asp-action="Create" class="crud-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ProductName" class="control-label"></label>
                                    <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
                                    <span asp-validation-for="ProductName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ProductSlug" class="control-label"></label>
                                    <input asp-for="ProductSlug" class="form-control" placeholder="e.g. iphone-15-pro" />
                                    <span asp-validation-for="ProductSlug" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="CategoryId" class="control-label">Category</label>
                                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="SeriesId" class="control-label">Series</label>
                                    <select asp-for="SeriesId" class="form-control" asp-items="ViewBag.SeriesId"></select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="SupplierId" class="control-label">Supplier</label>
                                    <select asp-for="SupplierId" class="form-control" asp-items="ViewBag.SupplierId"></select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="UnitPrice" class="control-label"></label>
                                    <input asp-for="UnitPrice" class="form-control" placeholder="0.00" />
                                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="Discount" class="control-label"></label>
                                    <input asp-for="Discount" class="form-control" placeholder="0" />
                                    <span asp-validation-for="Discount" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="StockQuantity" class="control-label"></label>
                                    <input asp-for="StockQuantity" class="form-control" placeholder="0" />
                                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="control-label"></label>
                            <input asp-for="Description" class="form-control" placeholder="Product description" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="crud-btn-group">
                            <button type="submit" class="crud-btn crud-btn--primary">
                                <i class="fa fa-check"></i> Create
                            </button>
                            <a asp-action="Index" class="crud-btn crud-btn--secondary">
                                <i class="fa fa-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
