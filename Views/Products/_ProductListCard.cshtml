@model TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel

@{
    var isOutOfStock = Model.StockQuantity <= 0;
}

<div class="product__item @(isOutOfStock ? "is-sold-out" : "")">
    <!-- 1. Picture Pillar -->
    <div class="product__item__pic set-bg" data-setbg="@Url.Content(Model.PrimaryImage ?? "~/img/product/product-1.jpg")">
        @if (isOutOfStock)
        {
            <div class="sold-out-overlay">
                <span class="sold-out-text">Hết hàng</span>
            </div>
        }

        @if (Model.IsOnSale)
        {
            <div class="product__discount__percent">-@Model.DiscountPercent.ToString("0")%</div>
        }
        <ul class="product__item__pic__hover">
            <li><a href="javascript:void(0)" class="toggle-favorite" data-product-id="@Model.ProductId"><i class="fa fa-heart @(Model.IsFavorite ? "is-favorite" : "")"></i></a></li>
            <li><a href="#"><i class="fa fa-retweet"></i></a></li>
            <li>
                <a href="javascript:void(0)" 
                   class="add-to-cart-btn @(isOutOfStock ? "btn-disabled" : "")" 
                   data-product-id="@Model.ProductId"
                   disabled="@(isOutOfStock ? "disabled" : null)">
                    <i class="fa fa-shopping-cart"></i>
                </a>
            </li>
        </ul>
    </div>

    <!-- 2. Text Pillar -->
    <div class="product__item__text cursor-pointer" onclick="window.location.href='@Url.Action("Details", "Products", new { id = Model.ProductId })'">
        <span class="product-category-label d-block text-muted small mb-1">@Model.CategoryName</span>
        <h6><a asp-controller="Products" asp-action="Details" asp-route-id="@Model.ProductId">@Model.ProductName</a></h6>
        
        <!-- Detailed Info for List Mode -->
        <div class="product__item__list-meta mb-2">
            <div class="product__item__rating d-inline-block mr-3">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fa @(i <= Math.Round(Model.AverageRating) ? "fa-star" : "fa-star-o") star-rating-icon"></i>
                }
                <span class="text-muted small ml-1">(@Model.AverageRating.ToString("0.0"))</span>
            </div>
            <div class="product__item__view-count d-inline-block mr-3">
                <i class="fa fa-eye text-muted"></i> <span class="text-muted small">@Model.ViewCount.ToString("N0")</span>
            </div>
            <div class="product__item__stock d-inline-block">
                @if (!isOutOfStock)
                {
                    <span class="badge badge-stock badge-stock-in">Còn hàng (@Model.StockQuantity)</span>
                }
                else
                {
                    <span class="badge badge-stock badge-stock-out">Hết hàng</span>
                }
            </div>
        </div>
        
        @if (Model.IsOnSale)
        {
            <div class="product__item__price">
                <span class="product-list-price-final">@Model.FinalPrice.ToString("N0")₫</span>
                <span class="old-price old-price-lg">@Model.UnitPrice.ToString("N0")₫</span>
            </div>
        }
        else
        {
            <h5 class="product-list-price-heading">@Model.UnitPrice.ToString("N0")₫</h5>
        }
    </div>

    <!-- 3. Actions Pillar (Right side in List Mode) -->
    <div class="product__item__list-actions">
        <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.ProductId" 
           class="primary-btn @(isOutOfStock ? "btn-disabled" : "")"
           onclick="@(isOutOfStock ? "return false;" : null)">
            @(isOutOfStock ? "Hết hàng" : "Chi tiết")
        </a>
    </div>
</div>
