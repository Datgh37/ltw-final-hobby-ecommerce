@model TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel

@{
    var colClass = ViewData["ColClass"] as string ?? "col-lg-4 col-md-6 col-sm-6 col-6";
    var extraClasses = ViewData["ExtraClasses"] as string ?? "";
    var showCategory = ViewData["ShowCategory"] as bool? ?? false;
    var isFeatured = ViewData["IsFeatured"] as bool? ?? false;
    var isOutOfStock = Model.StockQuantity <= 0;
    
    // Determine the base class (Featured uses featured__item, others use product__item)
    var baseClass = isFeatured ? "featured__item" : "product__item";
    var picClass = isFeatured ? "featured__item__pic" : "product__item__pic";
    var textClass = isFeatured ? "featured__item__text" : "product__item__text";
}

<div class="@colClass @extraClasses">
    <div class="@baseClass @(isOutOfStock ? "is-sold-out" : "")">
        <div class="@picClass set-bg" data-setbg="@Url.Content(Model.PrimaryImage ?? "~/images/Others/product-1.jpg")">
            @if (isOutOfStock)
            {
                <div class="sold-out-overlay">
                    <span class="sold-out-text">Hết hàng</span>
                </div>
            }
            
            @if (Model.IsOnSale)
            {
                <div class="product__discount__percent">-@Model.DiscountPercent.ToString("0")%</div>
            }
            <ul class="@(isFeatured ? "featured__item__pic__hover" : "product__item__pic__hover")">
                <li><a href="javascript:void(0)" class="toggle-favorite" data-product-id="@Model.ProductId"><i class="fa fa-heart @(Model.IsFavorite ? "is-favorite" : "")"></i></a></li>
                <li><a href="#"><i class="fa fa-retweet"></i></a></li>
                <li>
                    <a href="javascript:void(0)" 
                       class="add-to-cart-btn @(isOutOfStock ? "btn-disabled" : "")" 
                       data-product-id="@Model.ProductId"
                       disabled="@(isOutOfStock ? "disabled" : null)">
                        <i class="fa fa-shopping-cart"></i>
                    </a>
                </li>
            </ul>
        </div>
        <div class="@textClass cursor-pointer" onclick="window.location.href='@Url.Action("Details", "Products", new { id = Model.ProductId })'">
            @if (showCategory && !string.IsNullOrEmpty(Model.CategoryName))
            {
                <span class="product-category-label d-block text-muted small mb-1">@Model.CategoryName</span>
            }
            <h6><a asp-controller="Products" asp-action="Details" asp-route-id="@Model.ProductId">@Model.ProductName</a></h6>
            @if (Model.IsOnSale)
            {
                <div class="product__item__price">
                    @Model.FinalPrice.ToString("N0")₫
                    <span class="old-price old-price-sm">@Model.UnitPrice.ToString("N0")₫</span>
                </div>
            }
            else
            {
                <h5>@Model.UnitPrice.ToString("N0")₫</h5>
            }
        </div>
    </div>
</div>

