@model IReadOnlyList<TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel>

@if (Model.Count > 0)
{
    <div class="product__discount">
        <div class="section-title product__discount__title">
            <h2>Sale Off</h2>
        </div>
        <div class="row">
            <div class="product__discount__slider owl-carousel">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4">
                        <div class="product__discount__item">
                            <div class="product__discount__item__pic set-bg" data-setbg="@Url.Content(item.PrimaryImage ?? "~/img/product/discount/pd-1.jpg")">
                                @if (item.IsOnSale)
                                {
                                    <div class="product__discount__percent">-@item.DiscountPercent.ToString("0")%</div>
                                }
                                <ul class="product__item__pic__hover">
                                    <li><a href="#"><i class="fa fa-heart"></i></a></li>
                                    <li><a href="#"><i class="fa fa-retweet"></i></a></li>
                                    <li><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"><i class="fa fa-shopping-cart"></i></a></li>
                                </ul>
                            </div>
                            <div class="product__discount__item__text" onclick="window.location.href='@Url.Action("Details", "Products", new { id = item.ProductId })'" style="cursor: pointer;">
                                @if (!string.IsNullOrWhiteSpace(item.CategoryName))
                                {
                                    <span>@item.CategoryName</span>
                                }
                                <h5><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.ProductName</a></h5>
                                <div class="product__item__price">
                                    @item.FinalPrice.ToString("N0")₫
                                    <span>@item.UnitPrice.ToString("N0")₫</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
