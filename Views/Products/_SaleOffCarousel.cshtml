@model IReadOnlyList<TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel>

@if (Model.Count > 0)
{
    <div class="product__discount">
        <div class="section-title product__discount__title">
            <h2>@Loc.T("Khuyến Mãi Đặc Biệt", "Special Discounts")</h2>
        </div>
        <div class="row">
            <div class="product__discount__slider owl-carousel">
                @foreach (var item in Model)
                {
                    var viewData = new ViewDataDictionary(ViewData)
                    {
                        { "ColClass", "col-lg-4" },
                        { "ShowCategory", true }
                    };
                    @await Html.PartialAsync("_ProductCard", item, viewData)
                }
            </div>
        </div>
    </div>
}
