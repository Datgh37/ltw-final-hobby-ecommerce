@model TuNhanTamTInh_Ecommerce.Models.ViewModels.PaginationViewModel

@if (Model.TotalPages > 1)
{
    <div class="product__pagination">
        @if (Model.ShowArrows && Model.HasPreviousPage)
        {
            <a asp-controller="Products"
               asp-action="Index"
               asp-route-page="@(Model.CurrentPage - 1)"
               asp-route-categoryId="@Model.Query.CategoryId"
               asp-route-seriesId="@Model.Query.SeriesId"
               asp-route-keyword="@Model.Query.Keyword"
               asp-route-sort="@Model.Query.Sort"
               asp-route-minPrice="@Model.Query.MinPrice"
               asp-route-maxPrice="@Model.Query.MaxPrice">
                <i class="fa fa-long-arrow-left"></i>
            </a>
        }

        @{
            var startPage = Math.Max(1, Model.CurrentPage - 2);
            var endPage = Math.Min(Model.TotalPages, startPage + 4);
            if (endPage - startPage < 4)
            {
                startPage = Math.Max(1, endPage - 4);
            }
        }

        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
        {
            <a class="@(pageNumber == Model.CurrentPage ? "active" : null)"
               asp-controller="Products"
               asp-action="Index"
               asp-route-page="@pageNumber"
               asp-route-categoryId="@Model.Query.CategoryId"
               asp-route-seriesId="@Model.Query.SeriesId"
               asp-route-keyword="@Model.Query.Keyword"
               asp-route-sort="@Model.Query.Sort"
               asp-route-minPrice="@Model.Query.MinPrice"
               asp-route-maxPrice="@Model.Query.MaxPrice">@pageNumber</a>
        }

        @if (Model.ShowArrows && Model.HasNextPage)
        {
            <a asp-controller="Products"
               asp-action="Index"
               asp-route-page="@(Model.CurrentPage + 1)"
               asp-route-categoryId="@Model.Query.CategoryId"
               asp-route-seriesId="@Model.Query.SeriesId"
               asp-route-keyword="@Model.Query.Keyword"
               asp-route-sort="@Model.Query.Sort"
               asp-route-minPrice="@Model.Query.MinPrice"
               asp-route-maxPrice="@Model.Query.MaxPrice">
                <i class="fa fa-long-arrow-right"></i>
            </a>
        }
    </div>
}
