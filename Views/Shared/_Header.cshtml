@using Microsoft.AspNetCore.Localization
@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.Culture.Name ?? "vi-VN";
    var isEnglish = currentCulture == "en-US";
}

<partial name="_HeaderHamburger.cshtml" />
<!-- Header Section Begin -->
<header class="header">

    <div class="container">
        <div class="row">
            <div class="col-lg-2 col-md-6 col-12 h-left d-flex justify-content-md-start justify-content-center">
                <div class="header__logo">
                    <a asp-controller="Home" asp-action="Index"><img src="~/images/Banner/logotoy.png" alt="Hobby Shop"></a>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 d-none d-lg-block">
                <nav class="header__menu">
                    <ul>
                        <li class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                            <a asp-controller="Home" asp-action="Index">@Loc.T("Trang chủ", "Home")</a>
                        </li>
                        <li class="@(currentController == "Products" ? "active" : "")">
                            <a asp-controller="Products" asp-action="Index">@Loc.T("Cửa hàng", "Shop")</a>
                        </li>
                        <li>
                            <a>@Loc.T("Trang", "Pages")</a>
                            <ul class="header__menu__dropdown">
                                <li><a asp-controller="Cart" asp-action="Index">@Loc.T("Giỏ hàng", "Cart")</a></li>
                                @if (User.Identity!.IsAuthenticated)
                                {
                                    <li><a asp-controller="Orders" asp-action="History">@Loc.T("Lịch sử đơn hàng", "Order History")</a></li>
                                    @if (User.FindFirst("RoleId")?.Value == "0")
                                    {
                                        <li><a asp-controller="Admin" asp-action="Products">@Loc.T("Quản lý sản phẩm", "Products Admin")</a></li>
                                        <li><a asp-controller="Admin" asp-action="Categories">@Loc.T("Quản lý danh mục", "Categories Admin")</a></li>
                                        <li><a asp-controller="Admin" asp-action="Orders">@Loc.T("Quản lý đơn hàng", "Orders Admin")</a></li>
                                    }
                                }
                            </ul>
                        </li>
                        <li class="@(currentController == "AboutUs" ? "active" : "")">
                            <a asp-controller="AboutUs" asp-action="Index">@Loc.T("Giới thiệu", "About Us")</a>
                        </li>
                    </ul>
                </nav>
            </div>
            <div class="col-lg-4 col-md-4 h-right d-none d-lg-flex">
                <partial name="_LanguageSelector" />
                <div class="header__tabs">
                    <ul>
                        <li><a asp-controller="Favorites" asp-action="Index"><i class="fa fa-heart"></i> <span id="favoriteCount">0</span></a></li>
                        <li class="cart-preview-wrapper">
                            <div class="cart-vc-content">
                                @await Component.InvokeAsync("Cart")
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="header__login">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown d-inline-block">
                            <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="@Url.Content(User.FindFirst("UserImage")?.Value ?? "~/images/user-default.png")" alt="Avatar" class="header__user-avatar">
                                <span class="header__user-name">@User.FindFirst("AccountId")?.Value</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-right shadow border-0" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="fa fa-user me-2"></i> @Loc.T("Hồ sơ", "Profile")</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="Cart" asp-action="Index"><i class="fa fa-shopping-bag me-2"></i> @Loc.T("Giỏ hàng", "Cart")</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="Orders" asp-action="History"><i class="fa fa-list-alt me-2"></i> @Loc.T("Lịch sử đơn hàng", "Order History")</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger py-2"><i class="fa fa-sign-out me-2"></i> @Loc.T("Đăng xuất", "Logout")</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"><i class="fa fa-user"></i> @Loc.T("Đăng nhập", "Login")</a>
                    }
                </div>
            </div>
        </div>
        <div class="humberger__open">
            <i class="fa fa-bars"></i>
        </div>
    </div>
</header>
<!-- Header Section End -->