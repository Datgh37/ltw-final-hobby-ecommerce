@using Microsoft.AspNetCore.Localization
@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.Culture.Name ?? "vi-VN";
    var isEnglish = currentCulture == "en-US";
}

<!-- Humberger Begin -->
<div class="humberger__menu__overlay"></div>
<div class="humberger__menu__wrapper">
    <div class="humberger__menu__logo">
        <a asp-controller="Home" asp-action="Index"><img src="~/images/Banner/logotoy.png" alt=""></a>
    </div>

    <!-- Phần người dùng -->
    <div class="humberger__menu__user border-bottom pb-4 mb-4">
        @if (User.Identity.IsAuthenticated)
        {
            <div class="d-flex align-items-center px-3">
                <img src="@Url.Content(User.FindFirst("UserImage")?.Value ?? "~/images/user-default.png")"
                     alt="Avatar" class="rounded-circle header-mobile-avatar mr-3">
                <div class="user-info">
                    <span class="d-block text-dark fw-bold h6 mb-1">@User.FindFirst("AccountId")?.Value</span>
                    <a asp-controller="Account" asp-action="Profile" class="d-block small text-purple text-decoration-none font-weight-bold mb-1">@Loc.T("Hồ sơ cá nhân", "My Profile") <i class="fa fa-angle-right"></i></a>
                    <a asp-controller="Orders" asp-action="History" class="d-block small text-purple text-decoration-none font-weight-bold mb-1">@Loc.T("Lịch sử đơn hàng", "Order History") <i class="fa fa-angle-right"></i></a>
                </div>
            </div>
        }
        else
        {
            <div class="px-3">
                <a asp-controller="Account" asp-action="Login" class="btn auth-btn w-100 text-white rounded-pill py-2">
                    <i class="fa fa-user mr-2"></i> @Loc.T("Đăng nhập", "Login")
                </a>
            </div>
        }
    </div>

    <div class="humberger__menu__cart">
        <ul>
            <li><a asp-controller="Favorites" asp-action="Index"><i class="fa fa-heart"></i> <span id="favoriteCountMobile">0</span></a></li>
            <li>
                <div class="cart-vc-content">
                    @await Component.InvokeAsync("Cart")
                </div>
            </li>
        </ul>
        <div class="header__cart__price">@Loc.T("Giỏ hàng: ", "Cart: ") <span>0 ₫</span></div>
    </div>
    <div class="humberger__menu__widget">
        <div class="header__top__right__language">
            @if (isEnglish)
            {
                <img src="~/images/america.png" alt="English" class="lang-flag-img" />
                <div>English</div>
            }
            else
            {
                <img src="~/images/vietnam.png" alt="Vietnam" class="lang-flag-img" />
                <div>Tiếng Việt</div>
            }
            <span class="arrow_carrot-down"></span>
            <ul>
                <li>
                    <a asp-controller="Language" asp-action="Change" asp-route-culture="vi-VN" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                       class="@(!isEnglish ? "disabled-lang active-lang" : "")">
                        <img src="~/images/vietnam.png" alt="Vietnam" class="lang-flag-img-dropdown" /> Tiếng Việt
                    </a>
                </li>
                <li>
                    <a asp-controller="Language" asp-action="Change" asp-route-culture="en-US" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                       class="@(isEnglish ? "disabled-lang active-lang" : "")">
                        <img src="~/images/america.png" alt="English" class="lang-flag-img-dropdown" /> English
                    </a>
                </li>
            </ul>
        </div>
    </div>
    <nav class="humberger__menu__nav mobile-menu">
        <ul>
            <li class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                <a asp-controller="Home" asp-action="Index">@Loc.T("Trang chủ", "Home")</a>
            </li>
            <li class="@(currentController == "Products" ? "active" : "")">
                <a asp-controller="Products" asp-action="Index">@Loc.T("Cửa hàng", "Shop")</a>
            </li>
            <li>
                <a href="#">@Loc.T("Trang", "Pages")</a>
                <ul class="header__menu__dropdown">
                    <li><a asp-controller="Cart" asp-action="Index">@Loc.T("Giỏ hàng", "Cart")</a></li>
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li><a asp-controller="Orders" asp-action="History">@Loc.T("Lịch sử đơn hàng", "Order History")</a></li>
                        @if (User.FindFirst("RoleId")?.Value == "0")
                        {
                            <li><a asp-controller="Admin" asp-action="Products">@Loc.T("Quản lý sản phẩm", "Products Admin")</a></li>
                            <li><a asp-controller="Admin" asp-action="Categories">@Loc.T("Quản lý danh mục", "Categories Admin")</a></li>
                            <li><a asp-controller="Admin" asp-action="Orders">@Loc.T("Quản lý đơn hàng", "Orders Admin")</a></li>
                        }
                    }
                </ul>
            </li>
            <li class="@(currentController == "AboutUs" ? "active" : "")">
                <a asp-controller="AboutUs" asp-action="Index">@Loc.T("Giới thiệu", "About Us")</a>
            </li>
            @if (User.Identity!.IsAuthenticated)
            {
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logout-mobile-form" class="m-0 p-0">
                        <a href="javascript:void(0);" onclick="document.getElementById('logout-mobile-form').submit();" class="text-danger fw-bold">
                            <i class="fa fa-sign-out"></i> @Loc.T("Đăng xuất", "Logout")
                        </a>
                    </form>
                </li>
            }
        </ul>
    </nav>
    <div id="mobile-menu-wrap"></div>
    <div class="header__top__right__social">
        <a href="#"><i class="fa fa-facebook"></i></a>
        <a href="#"><i class="fa fa-twitter"></i></a>
        <a href="#"><i class="fa fa-linkedin"></i></a>
        <a href="#"><i class="fa fa-pinterest-p"></i></a>
    </div>
    <div class="humberger__menu__contact">
        <ul>
            <li><i class="fa fa-envelope"></i> hello@nhom4.com</li>
            <li>@Loc.T("Miễn phí vận chuyển cho đơn hàng từ 99.000 ₫", "Free shipping for orders over 99,000 ₫")</li>
        </ul>
    </div>
</div>
<!-- Humberger End -->
