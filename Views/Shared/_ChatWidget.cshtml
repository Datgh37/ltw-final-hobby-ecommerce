<!-- Chatbot Floating Bubble -->
<div id="chatbot-bubble" class="chatbot-bubble" title="Hỏi đáp cùng AI Trợ lý">
    <div class="chatbot-bubble-pulse"></div>
    <i class="fa fa-comments"></i>
    <span class="chatbot-bubble-badge">AI Trợ Lý</span>
</div>

<!-- Chatbot Chat Window -->
<div id="chatbot-window" class="chatbot-window hidden">
    <!-- Chat Header -->
    <div class="chatbot-header">
        <div class="chatbot-header-info">
            <div class="chatbot-avatar">
                <img src="/images/Others/bot-avatar.png" alt="AI Avatar">
                <span class="online-indicator"></span>
            </div>
            <div class="chatbot-title-container">
                <h6 class="chatbot-title">Hobby Assistant</h6>
                <span class="chatbot-subtitle">AI Trợ lý trực tuyến</span>
            </div>
        </div>
        <div class="chatbot-header-actions">
            <button id="chatbot-resize" class="chatbot-resize-btn" title="Phóng to / Thu nhỏ"><i class="fa fa-expand"></i></button>
            <button id="chatbot-close" class="chatbot-close-btn">&times;</button>
        </div>
    </div>

    <!-- Chat Messages -->
    <div id="chatbot-messages" class="chatbot-messages">
        <!-- Bot Welcome Message -->
        <div class="chat-message bot">
            <div class="message-avatar">
                <img src="/images/Others/bot-avatar.png" alt="AI Avatar">
            </div>
            <div class="message-bubble">
                Chào bạn! Tôi là **Hobby Assistant** 🤖, trợ lý AI siêu cấp của shop. Bạn cần tìm kiếm Gundam, Figure, hay muốn hỏi về hàng giảm giá hot cứ bảo tôi nhé!
            </div>
        </div>

        <!-- Quick Suggestions -->
        <div class="chatbot-suggestions">
            <button class="suggestion-btn" data-query="Shop đang bày bán tổng cộng bao nhiêu mặt hàng?">📊 Số lượng sản phẩm</button>
            <button class="suggestion-btn" data-query="Hiện tại shop có mã giảm giá hoặc voucher nào không?">🎟️ Mã giảm giá / Voucher</button>
            <button class="suggestion-btn" data-query="Shop bán những danh mục và dòng series mô hình nào?">📂 Danh mục & Series</button>
            <button class="suggestion-btn" data-query="Có những sản phẩm nào mới về hoặc đang giảm giá sâu không?">🔥 Hàng Mới & Khuyến Mãi</button>
            <button class="suggestion-btn" data-query="Cho xem những mô hình đang hot nhất của shop">🏆 Sản phẩm Hot nhất</button>
            <button class="suggestion-btn" data-query="Địa chỉ, hotline liên hệ và email của shop là gì?">📞 Địa chỉ & Hotline</button>
            <button class="suggestion-btn" data-query="Quy trình đặt hàng, thanh toán và phí ship thế nào?">📦 Đặt hàng & Ship</button>
        </div>
    </div>

    <!-- Chat Input -->
    <div class="chatbot-input-container">
        <input type="text" id="chatbot-input" class="chatbot-input-field" placeholder="Nhập câu hỏi của bạn..." autocomplete="off">
        <button id="chatbot-send" class="chatbot-send-btn" title="Gửi câu hỏi">
            <i class="fa fa-paper-plane"></i>
        </button>
    </div>
</div>
