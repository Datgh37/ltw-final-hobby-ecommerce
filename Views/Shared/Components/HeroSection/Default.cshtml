@model TuNhanTamTInh_Ecommerce.Models.ViewModels.HeroSectionViewModel
@{
    var isHome = ViewData["IsHomePage"] as bool? ?? false;
}

<!-- Hero Section Begin -->
<section class="hero @(isHome ? "" : "hero-normal")">
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
                <div class="hero__categories">
                    <div class="hero__categories__all">
                        <i class="fa fa-bars"></i>
                        <span>All Categories</span>
                    </div>
                    <ul>
                        @foreach (var catItem in Model.Categories)
                        {
                            <li>
                                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@catItem.CategoryId">
                                    @catItem.CategoryName
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="col-lg-9">
                <div class="hero__search">
                    <div class="hero__search__form">
                        <form asp-controller="Product" asp-action="Index" method="get">
                            <select name="seriesId" class="hero-series-select">
                                <option value="" selected>All Series</option>
                                @foreach (var seriesItem in Model.Series)
                                {
                                    <option value="@seriesItem.SeriesId">@seriesItem.SeriesName</option>
                                }
                            </select>
                            <input type="text" name="keyword" placeholder="What do you need?">
                            <button type="submit" class="site-btn">SEARCH</button>
                        </form>
                    </div>
                    <div class="hero__search__phone">
                        <div class="hero__search__phone__icon">
                            <i class="fa fa-phone"></i>
                        </div>
                        <div class="hero__search__phone__text">
                            <h5>+65 11.188.888</h5>
                            <span>support 24/7 time</span>
                        </div>
                    </div>
                </div>

                @if (isHome)
                {
                    <partial name="_HomePageBanner" />
                }
            </div>
        </div>
    </div>
</section>
<!-- Hero Section End -->