@model IEnumerable<TuNhanTamTInh_Ecommerce.Models.ViewModels.ProductCardViewModel>
@{
    var latestProducts = Model.ToList();
    var slides = latestProducts.Chunk(3).ToList();
}

<div class="sidebar__item">
    <div class="latest-product__text">
        <h4>Latest Products</h4>
        <div class="latest-product__slider owl-carousel">
            @foreach (var slide in slides)
            {
                <div class="latest-prdouct__slider__item">
                    @foreach (var item in slide)
                    {
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="latest-product__item">
                            <div class="latest-product__item__pic">
                                <img src="@Url.Content(item.PrimaryImage ?? "~/img/latest-product/lp-1.jpg")" alt="@item.ProductName" />
                            </div>
                            <div class="latest-product__item__text">
                                <h6>@item.ProductName</h6>
                                <span>@item.FinalPrice.ToString("N0")₫</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
