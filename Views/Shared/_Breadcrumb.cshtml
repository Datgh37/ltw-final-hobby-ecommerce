@model TuNhanTamTInh_Ecommerce.Models.ViewModels.BreadcrumbViewModel

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="@Url.Content(Model.BackgroundImage)">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>@Model.Title</h2>
                    <div class="breadcrumb__option">
                        @foreach (var item in Model.Items)
                        {
                            if (!string.IsNullOrEmpty(item.Url))
                            {
                                <a href="@item.Url">@item.Text</a>
                            }
                            else
                            {
                                <span>@item.Text</span>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->
