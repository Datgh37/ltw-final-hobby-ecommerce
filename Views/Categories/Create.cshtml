@model TuNhanTamTInh_Ecommerce.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-controller="Categories" asp-action="Index">Categories</a>
                <span>/</span>
                <span>Create</span>
            </div>
            <h1><i class="fa fa-plus-circle"></i> Create New Category</h1>
            <p>Fill in the details below to add a new category.</p>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <h3 class="crud-card__title">
                        <i class="fa fa-th-list"></i> Category Information
                    </h3>
                    <form asp-action="Create" class="crud-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group">
                            <label asp-for="CategoryName" class="control-label"></label>
                            <input asp-for="CategoryName" class="form-control" placeholder="Enter category name" />
                            <span asp-validation-for="CategoryName" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="CategorySlug" class="control-label"></label>
                            <input asp-for="CategorySlug" class="form-control" placeholder="e.g. phones, laptops" />
                            <span asp-validation-for="CategorySlug" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Image" class="control-label"></label>
                            <input asp-for="Image" class="form-control" placeholder="Image URL" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>
                        <div class="crud-btn-group">
                            <button type="submit" class="crud-btn crud-btn--primary">
                                <i class="fa fa-check"></i> Create
                            </button>
                            <a asp-action="Index" class="crud-btn crud-btn--secondary">
                                <i class="fa fa-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
