@model TuNhanTamTInh_Ecommerce.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-controller="Categories" asp-action="Index">Categories</a>
                <span>/</span>
                <span>Delete</span>
            </div>
            <h1><i class="fa fa-trash"></i> Delete Category</h1>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <!-- Warning -->
                    <div class="crud-delete-warning">
                        <i class="fa fa-exclamation-triangle"></i>
                        <span>Are you sure you want to delete this category? This action cannot be undone.</span>
                    </div>

                    <h3 class="crud-card__title">
                        <i class="fa fa-th-list"></i> @Model.CategoryName
                    </h3>
                    <dl class="crud-detail-list">
                        <dt>Category Name</dt>
                        <dd>@Html.DisplayFor(model => model.CategoryName)</dd>
                        <dt>Slug</dt>
                        <dd><code>@Html.DisplayFor(model => model.CategorySlug)</code></dd>
                        <dt>Image</dt>
                        <dd>@Html.DisplayFor(model => model.Image)</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="CategoryId" />
                        <div class="crud-btn-group">
                            <button type="submit" class="crud-btn crud-btn--danger">
                                <i class="fa fa-trash"></i> Confirm Delete
                            </button>
                            <a asp-action="Index" class="crud-btn crud-btn--secondary">
                                <i class="fa fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
