@model TuNhanTamTInh_Ecommerce.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<section class="crud-page">
    <div class="container">
        <div class="crud-page__header">
            <div class="crud-page__breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-controller="Categories" asp-action="Index">Categories</a>
                <span>/</span>
                <span>Details</span>
            </div>
            <h1><i class="fa fa-info-circle"></i> Category Details</h1>
        </div>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="crud-card">
                    <h3 class="crud-card__title">
                        <i class="fa fa-th-list"></i> @Model.CategoryName
                    </h3>
                    <dl class="crud-detail-list">
                        <dt>Category Name</dt>
                        <dd>@Html.DisplayFor(model => model.CategoryName)</dd>
                        <dt>Slug</dt>
                        <dd><code>@Html.DisplayFor(model => model.CategorySlug)</code></dd>
                        <dt>Image</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.Image))
                            {
                                <img src="@Model.Image" alt="@Model.CategoryName" class="crud-img-preview" style="width:120px; height:auto;" />
                            }
                            else
                            {
                                <span style="color:#ccc;">No image</span>
                            }
                        </dd>
                    </dl>
                    <div class="crud-btn-group">
                        <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="crud-btn crud-btn--primary">
                            <i class="fa fa-pencil"></i> Edit
                        </a>
                        <a asp-action="Index" class="crud-btn crud-btn--secondary">
                            <i class="fa fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
