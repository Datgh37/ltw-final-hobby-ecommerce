@using TuNhanTamTInh_Ecommerce.Models
@using TuNhanTamTInh_Ecommerce.Models.ViewModels
@model List<Favorite>

@{
    ViewData["Title"] = Loc.T("Sản phẩm yêu thích", "My Wishlist");
    var breadcrumb = ViewBag.Breadcrumb as BreadcrumbViewModel;
}

@await Component.InvokeAsync("HeroSection", new { isHome = false })

<partial name="_Breadcrumb" model="breadcrumb" />

<section class="shoping-cart spad">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="row">
                <div class="col-12">
                    <div class="favorites-empty text-center py-5">
                        <div class="favorites-empty__icon mb-4">
                            <i class="fa fa-heart-o"></i>
                        </div>
                        <h5 class="mb-2">@Loc.T("Danh sách yêu thích trống", "Wishlist is empty")</h5>
                        <p class="text-muted mb-4">@Loc.T("Hãy khám phá cửa hàng và thêm sản phẩm yêu thích của bạn!", "Explore the shop and add your favorite products!")</p>
                        <a asp-controller="Products" asp-action="Index" class="primary-btn">
                            <i class="fa fa-shopping-bag me-2"></i> @Loc.T("Khám phá sản phẩm", "Explore Products")
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-12">
                    <div class="shoping__cart__table">
                        <table>
                            <thead>
                                <tr>
                                    <th class="fav-product-header">@Loc.T("Sản phẩm", "Products")</th>
                                    <th class="fav-price-cell">@Loc.T("Giá", "Price")</th>
                                    <th class="fav-status-cell">@Loc.T("Trạng thái", "Status")</th>
                                    <th class="shoping__cart__item__close"></th>
                                </tr>
                            </thead>
                            <tbody id="favorites-tbody">
                                @foreach (var item in Model)
                                {
                                    var product = item.Product;
                                    var primaryImage = product.ProductImages?.FirstOrDefault(x => x.IsPrimary)
                                                    ?? product.ProductImages?.FirstOrDefault();
                                    var imageUrl = primaryImage?.ImageUrl ?? "~/images/product-default.png";
                                    var finalPrice = product.Discount > 0
                                        ? product.UnitPrice * (1 - (decimal)product.Discount)
                                        : product.UnitPrice;
                                    var isInStock = product.StockQuantity > 0;

                                    var reviewsList = product.Reviews;
                                    double avgRating = reviewsList != null && reviewsList.Any() ? reviewsList.Average(r => r.Rating) : 0.0;

                                    <tr class="fav-row" data-product-id="@product.ProductId">
                                        <td class="fav-product-cell">
                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">
                                                <img src="@Url.Content(imageUrl)"
                                                     class="cart-item-img fav-item-img"
                                                     alt="@product.ProductName"
                                                     onerror="this.src='/images/product-default.png'" />
                                            </a>
                                            <h5 class="fav-product-title-wrapper">
                                                @if (product.Category != null)
                                                {
                                                    <span class="product-category-label d-block text-muted small mb-1" style="font-size: 12px; color: #888; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">@product.Category.CategoryName</span>
                                                }
                                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId"
                                                   class="text-dark text-decoration-none fav-product-title"
                                                   title="@product.ProductName">
                                                    @product.ProductName
                                                </a>
                                                <div class="fav-product-meta">
                                                    <div class="fav-rating text-warning small d-inline-block">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="fa @(i <= Math.Round(avgRating) ? "fa-star" : "fa-star-o")"></i>
                                                        }
                                                        <span class="text-muted ml-1">(@avgRating.ToString("0.0"))</span>
                                                    </div>
                                                    <span class="fav-meta-sep">|</span>
                                                    <div class="fav-views text-muted small d-inline-block">
                                                        <i class="fa fa-eye"></i> <span>@product.ViewCount.ToString("N0") @Loc.T("lượt xem", "views")</span>
                                                    </div>
                                                </div>
                                            </h5>
                                        </td>
                                        <td class="fav-price-cell">
                                            @if (product.Discount > 0)
                                            {
                                                <span class="fav-final-price">@finalPrice.ToString("N0")₫</span>
                                                <br />
                                                <span class="old-price old-price-sm">@product.UnitPrice.ToString("N0")₫</span>
                                            }
                                            else
                                            {
                                                <span class="fav-final-price">@product.UnitPrice.ToString("N0")₫</span>
                                            }
                                        </td>
                                        <td class="fav-status-cell">
                                            @if (isInStock)
                                            {
                                                <span class="fav-stock-badge fav-stock-in">
                                                    <i class="fa fa-check-circle me-1"></i>@Loc.T("Còn hàng", "In Stock") (@product.StockQuantity)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="fav-stock-badge fav-stock-out">
                                                    <i class="fa fa-times-circle me-1"></i>@Loc.T("Hết hàng", "Out of Stock")
                                                </span>
                                            }
                                        </td>
                                        <td class="shoping__cart__item__close">
                                            <div class="fav-actions">
                                                <button type="button"
                                                        class="btn-add-to-cart-fav primary-btn primary-btn--sm @(isInStock ? "" : "disabled")"
                                                        data-product-id="@product.ProductId"
                                                    @(isInStock ? "" : "disabled")
                                                         title="@Loc.T("Thêm vào giỏ hàng", "Add to Cart")">
                                                    <i class="fa fa-shopping-cart"></i>
                                                </button>
                                                <button type="button"
                                                        class="btn-remove-fav fav-remove-btn"
                                                        data-product-id="@product.ProductId"
                                                        title="@Loc.T("Xóa khỏi yêu thích", "Remove from Wishlist")">
                                                    <span class="icon_close"></span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>


        }
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            var token = $('input[name="__RequestVerificationToken"]').val();

            // Xóa khỏi yêu thích
            $(document).on('click', '.btn-remove-fav', function () {
                var $btn = $(this);
                var productId = $btn.data('product-id');
                var $row = $btn.closest('.fav-row');

                $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');

                $.ajax({
                    url: '/Favorites/Remove',
                    type: 'POST',
                    data: { productId: productId },
                    headers: { 'RequestVerificationToken': token },
                    success: function (res) {
                        if (res.success) {
                            $row.fadeOut(300, function () {
                                $row.remove();
                                var remaining = $('#favorites-tbody .fav-row').length;
                                $('#fav-total-count').text(remaining);
                                $('.favorites-count-badge').text(remaining);
                                $('#favoriteCount, #favoriteCountMobile').text(res.totalCount);

                                if (remaining === 0) {
                                    location.reload();
                                }
                            });
                            showToast(res.message, 'success');
                        } else {
                            showToast(res.message, 'error');
                            $btn.prop('disabled', false).html('<span class="icon_close"></span>');
                        }
                    },
                    error: function () {
                        showToast('@Html.Raw(Loc.T("Có lỗi xảy ra. Vui lòng thử lại.", "An error occurred. Please try again."))', 'error');
                        $btn.prop('disabled', false).html('<span class="icon_close"></span>');
                    }
                });
            });

            // Thêm vào giỏ hàng từ trang yêu thích
            $(document).on('click', '.btn-add-to-cart-fav:not(.disabled)', function () {
                var productId = $(this).data('product-id');
                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { productId: productId, quantity: 1 },
                    headers: { 'RequestVerificationToken': token },
                    success: function (res) {
                        if (res.success) {
                            showToast('@Html.Raw(Loc.T("Đã thêm vào giỏ hàng!", "Added to cart!"))', 'success');
                            // Cập nhật badge giỏ hàng nếu có
                            if (res.cartCount !== undefined) {
                                $('#cartCount, #cartCountMobile').text(res.cartCount);
                            }
                            // Đồng bộ hóa danh sách Preview giỏ hàng khi Hover!
                            if (typeof reloadCartPreview === 'function') {
                                reloadCartPreview();
                            }
                        } else {
                            showToast(res.message || '@Html.Raw(Loc.T("Không thể thêm vào giỏ hàng.", "Could not add to cart."))', 'error');
                        }
                    },
                    error: function () {
                        showToast('@Html.Raw(Loc.T("Vui lòng đăng nhập để thêm vào giỏ hàng.", "Please login to add to cart."))', 'error');
                    }
                });
            });
        });
    </script>
}
