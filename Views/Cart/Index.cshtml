@using TuNhanTamTInh_Ecommerce.Models.ViewModels
@model List<CartItem>
@{
    ViewData["Title"] = Loc.T("Giỏ hàng", "Shopping Cart");
    decimal grandTotal = Model.Sum(x => x.Quantity * x.Product.UnitPrice);

    var breadcrumb = new BreadcrumbViewModel
    {
        Title = Loc.T("Giỏ hàng", "Shopping Cart"),
        Items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(Loc.T("Trang chủ", "Home"), Url.Action("Index", "Home")),
            new BreadcrumbItem(Loc.T("Chi tiết giỏ hàng", "Cart Details"))
        }
    };
}

@await Component.InvokeAsync("HeroSection", new { isHome = false })

<partial name="_Breadcrumb" model="breadcrumb" />

<section class="shoping-cart spad">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row">
                <div class="col-lg-12">
                    <div class="shoping__cart__table">
                        <table>
                            <thead>
                                <tr>
                                    <th class="cart-product-header">@Loc.T("Sản phẩm", "Products")</th>
                                    <th>@Loc.T("Giá", "Price")</th>
                                    <th>@Loc.T("Số lượng", "Quantity")</th>
                                    <th>@Loc.T("Tổng cộng", "Total")</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var primaryImage = item.Product.ProductImages.FirstOrDefault(x => x.IsPrimary);
                                    decimal subtotal = item.Product.UnitPrice * item.Quantity;
                                    <tr class="cart-row" data-cart-item-id="@item.CartItemId">
                                        <td class="cart-product-cell">
                                            <img src="@Url.Content(primaryImage?.ImageUrl ?? "~/images/product-default.png")" class="cart-item-img" alt="@item.Product.ProductName">
                                            <h5 class="cart-product-title">@item.Product.ProductName</h5>
                                        </td>
                                        <td class="shoping__cart__price">
                                            @item.Product.UnitPrice.ToString("N0")&nbsp;₫
                                        </td>
                                        <td class="shoping__cart__quantity">
                                            <div class="pro-qty-cart" data-max-stock="@item.Product.StockQuantity">
                                                <span class="dec qtybtn">-</span>
                                                <input type="text" class="qty-input" value="@item.Quantity" readonly>
                                                <span class="inc qtybtn">+</span>
                                            </div>
                                        </td>
                                        <td class="shoping__cart__total subtotal">
                                            @subtotal.ToString("N0")&nbsp;₫
                                        </td>
                                        <td class="shoping__cart__item__close">
                                            <a href="javascript:void(0)" class="delete-cart-item" data-cart-item-id="@item.CartItemId">
                                                <span class="icon_close"></span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="shoping__cart__btns">
                        <a asp-controller="Products" asp-action="Index" class="site-btn rounded-pill">@Loc.T("TIẾP TỤC MUA SẮM", "CONTINUE SHOPPING")</a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="shoping__continue">
                        <div class="shoping__discount">
                            <h5>@Loc.T("Mã giảm giá", "Discount Codes")</h5>
                            <form action="#">
                                <input type="text" placeholder="@Loc.T("Nhập mã giảm giá...", "Enter coupon code...")">
                                <button type="submit" class="site-btn rounded-pill">@Loc.T("ÁP DỤNG", "APPLY")</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="shoping__checkout">
                        <h5>@Loc.T("Tổng đơn hàng", "Cart Total")</h5>
                        <ul>
                            <li>@Loc.T("Tạm tính", "Subtotal") <span>@grandTotal.ToString("N0")&nbsp;₫</span></li>
                            <li>@Loc.T("Tổng cộng", "Total") <span id="grand-total">@grandTotal.ToString("N0")&nbsp;₫</span></li>
                        </ul>
                        <a asp-controller="Checkout" asp-action="Index" class="primary-btn rounded-pill w-100 text-center">@Loc.T("TIẾN HÀNH THANH TOÁN", "PROCEED TO CHECKOUT")</a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12">
                    <div class="cart-empty text-center py-5">
                        <div class="cart-empty__icon mb-4">
                            <i class="fa fa-shopping-basket"></i>
                        </div>
                        <h5 class="mb-2">@Loc.T("Giỏ hàng của bạn đang trống", "Your shopping cart is empty")</h5>
                        <p class="text-muted mb-4">@Loc.T("Hãy khám phá cửa hàng và chọn những mô hình Gundam ưng ý nhất nhé!", "Explore the shop and pick the best Gundam models for yourself!")</p>
                        <a asp-controller="Products" asp-action="Index" class="primary-btn rounded-pill">
                            <i class="fa fa-shopping-bag me-2"></i> @Loc.T("MUA SẮM NGAY", "SHOP NOW")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>