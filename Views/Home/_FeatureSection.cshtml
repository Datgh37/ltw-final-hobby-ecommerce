@model TuNhanTamTInh_Ecommerce.Models.ViewModels.HomeViewModel

<section class="featured spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title">
                    <h2>@Loc.T("Sản phẩm nổi bật", "Featured Products")</h2>
                </div>
                <div class="featured__controls">
                    <ul>
                        <li class="active" data-filter="*">@Loc.T("Tất cả", "All")</li>
                        @foreach (var cat in Model.FeaturedCategories)
                        {
                            <li data-filter=".cat-@cat.CategoryId">@cat.CategoryName</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="row featured__filter">
            @foreach (var item in Model.FeaturedProducts)
            {
                var viewData = new ViewDataDictionary(ViewData)
                {
                    { "ColClass", "col-lg-3 col-md-4 col-sm-6 col-6" },
                    { "ExtraClasses", $"mix cat-{item.CategoryId}" },
                    { "IsFeatured", true },
                    { "ShowCategory", true }
                };
                @await Html.PartialAsync("../Products/_ProductCard", item, viewData)
            }
        </div>
    </div>
</section>
