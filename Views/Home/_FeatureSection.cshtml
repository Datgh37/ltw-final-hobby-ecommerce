@model TuNhanTamTInh_Ecommerce.Models.ViewModels.HomeViewModel

<section class="featured spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title">
                    <h2>Featured Product</h2>
                </div>
                <div class="featured__controls">
                    <ul>
                        <li class="active" data-filter="*">All</li>
                        @foreach (var cat in Model.FeaturedCategories)
                        {
                            <li data-filter=".cat-@cat.CategoryId">@cat.CategoryName</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="row featured__filter">
            @foreach (var item in Model.FeaturedProducts)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mix cat-@item.CategoryId">
                    <div class="featured__item">
                        <div class="featured__item__pic set-bg" data-setbg="@Url.Content(item.PrimaryImage ?? "~/img/featured/feature-1.jpg")">
                            <ul class="featured__item__pic__hover">
                                <li><a href="#"><i class="fa fa-heart"></i></a></li>
                                <li><a href="#"><i class="fa fa-retweet"></i></a></li>
                                <li><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"><i class="fa fa-shopping-cart"></i></a></li>
                            </ul>
                        </div>
                        <div class="featured__item__text" onclick="window.location.href='@Url.Action("Details", "Products", new { id = item.ProductId })'" style="cursor: pointer;">
                            <h6><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.ProductName</a></h6>
                            <h5>@item.FinalPrice.ToString("N0")₫</h5>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
